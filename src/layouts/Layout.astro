---
interface Props {
  title: string;
  description?: string;
}

import { Icon } from "astro-icon/components";
import "../app.css";
const { title, description = "Centro de Salud Holística del Dr. Joaquín Ipinza. Odontología biológica, implantes cerámicos, tratamiento de ATM y más. Los Dominicos, Las Condes, Santiago." } = Astro.props;
---

<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="description" content={description} />
  <meta name="author" content="Dr. Joaquín Ipinza Hofmann" />
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  <title>{title}</title>
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=Merriweather:ital,wght@0,400;0,700;1,400&display=swap" rel="stylesheet" />
</head>
<body class="bg-neutral-50 text-neutral-800 font-body antialiased min-h-screen flex flex-col">

  <!-- HEADER -->
  <header class="bg-white border-b border-neutral-200 sticky top-0 z-50">
    <nav class="max-w-5xl mx-auto px-4 sm:px-6 h-16 flex items-center justify-between">
      <a href="/" class="flex items-center gap-2.5 no-underline">
        <div class="w-8 h-8 bg-emerald-700 rounded-lg flex items-center justify-center">
          <Icon name="lucide:heart-pulse" class="w-4 h-4 text-white" />
        </div>
        <div>
          <span class="font-heading font-bold text-sm text-emerald-900 leading-tight block">Centro de Salud</span>
          <span class="font-heading text-xs text-emerald-600 leading-tight block">Holística</span>
        </div>
      </a>

      <div class="hidden md:flex items-center gap-1">
        <a href="/libro" class="px-3 py-2 text-sm font-medium text-neutral-600 hover:text-emerald-700 hover:bg-emerald-50 rounded-md transition-colors no-underline inline-flex items-center gap-1.5">
          <Icon name="lucide:book-open" class="w-4 h-4" /> Libro
        </a>
        <a href="/servicios" class="px-3 py-2 text-sm font-medium text-neutral-600 hover:text-emerald-700 hover:bg-emerald-50 rounded-md transition-colors no-underline inline-flex items-center gap-1.5">
          <Icon name="lucide:stethoscope" class="w-4 h-4" /> Servicios
        </a>
        <a href="/aprende" class="px-3 py-2 text-sm font-medium text-neutral-600 hover:text-emerald-700 hover:bg-emerald-50 rounded-md transition-colors no-underline inline-flex items-center gap-1.5">
          <Icon name="lucide:graduation-cap" class="w-4 h-4" /> Aprende
        </a>
        <a href="/sobre" class="px-3 py-2 text-sm font-medium text-neutral-600 hover:text-emerald-700 hover:bg-emerald-50 rounded-md transition-colors no-underline inline-flex items-center gap-1.5">
          <Icon name="lucide:user-round" class="w-4 h-4" /> Doctor
        </a>
        <a href="/clinica" class="px-3 py-2 text-sm font-medium text-neutral-600 hover:text-emerald-700 hover:bg-emerald-50 rounded-md transition-colors no-underline inline-flex items-center gap-1.5">
          <Icon name="lucide:map-pin" class="w-4 h-4" /> Clínica
        </a>
        <a href="/contacto" class="ml-2 px-4 py-2 text-sm font-semibold bg-emerald-700 text-white rounded-lg hover:bg-emerald-800 transition-colors no-underline">
          Agendar Hora
        </a>
      </div>

      <button id="mobile-menu-btn" class="md:hidden p-2 text-neutral-600 hover:text-emerald-700 rounded-md" aria-label="Menú">
        <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16"></path></svg>
      </button>
    </nav>

    <div id="mobile-menu" class="hidden md:hidden border-t border-neutral-100 bg-white px-4 py-3">
      <div class="flex flex-col gap-1">
        <a href="/libro" class="px-3 py-2.5 text-sm font-medium text-neutral-600 hover:text-emerald-700 hover:bg-emerald-50 rounded-md no-underline inline-flex items-center gap-2">
          <Icon name="lucide:book-open" class="w-4 h-4" /> Libro
        </a>
        <a href="/servicios" class="px-3 py-2.5 text-sm font-medium text-neutral-600 hover:text-emerald-700 hover:bg-emerald-50 rounded-md no-underline inline-flex items-center gap-2">
          <Icon name="lucide:stethoscope" class="w-4 h-4" /> Servicios
        </a>
        <a href="/aprende" class="px-3 py-2.5 text-sm font-medium text-neutral-600 hover:text-emerald-700 hover:bg-emerald-50 rounded-md no-underline inline-flex items-center gap-2">
          <Icon name="lucide:graduation-cap" class="w-4 h-4" /> Aprende
        </a>
        <a href="/sobre" class="px-3 py-2.5 text-sm font-medium text-neutral-600 hover:text-emerald-700 hover:bg-emerald-50 rounded-md no-underline inline-flex items-center gap-2">
          <Icon name="lucide:user-round" class="w-4 h-4" /> Doctor
        </a>
        <a href="/clinica" class="px-3 py-2.5 text-sm font-medium text-neutral-600 hover:text-emerald-700 hover:bg-emerald-50 rounded-md no-underline inline-flex items-center gap-2">
          <Icon name="lucide:map-pin" class="w-4 h-4" /> Clínica
        </a>
        <a href="/contacto" class="mt-2 px-4 py-2.5 text-sm font-semibold bg-emerald-700 text-white rounded-lg text-center no-underline">Agendar Hora</a>
      </div>
    </div>
  </header>

  <main class="flex-1">
    <slot />
  </main>

  <!-- FOOTER -->
  <footer class="bg-emerald-900 text-emerald-200 mt-20">
    <div class="max-w-5xl mx-auto px-4 sm:px-6 py-14">
      <div class="grid md:grid-cols-4 gap-10">
        <div>
          <div class="flex items-center gap-2.5 mb-4">
            <div class="w-8 h-8 bg-emerald-700 rounded-lg flex items-center justify-center">
              <Icon name="lucide:heart-pulse" class="w-4 h-4 text-white" />
            </div>
            <div>
              <span class="font-heading font-bold text-sm text-white block">Centro de Salud</span>
              <span class="font-heading text-xs text-emerald-300 block">Holística</span>
            </div>
          </div>
          <p class="text-sm text-emerald-300 leading-relaxed">
            Odontología biológica y holística en Santiago. Cuidamos tu salud bucal en armonía con tu cuerpo y tu vida.
          </p>
        </div>

        <div>
          <h3 class="font-semibold text-white text-sm uppercase tracking-wider mb-4">Navegación</h3>
          <div class="flex flex-col gap-2.5 text-sm">
            <a href="/libro" class="text-emerald-300 hover:text-white transition-colors no-underline inline-flex items-center gap-2"><Icon name="lucide:book-open" class="w-4 h-4" /> Libro gratuito</a>
            <a href="/servicios" class="text-emerald-300 hover:text-white transition-colors no-underline inline-flex items-center gap-2"><Icon name="lucide:stethoscope" class="w-4 h-4" /> Servicios</a>
            <a href="/aprende" class="text-emerald-300 hover:text-white transition-colors no-underline inline-flex items-center gap-2"><Icon name="lucide:graduation-cap" class="w-4 h-4" /> Aprende</a>
            <a href="/sobre" class="text-emerald-300 hover:text-white transition-colors no-underline inline-flex items-center gap-2"><Icon name="lucide:user-round" class="w-4 h-4" /> Doctor</a>
            <a href="/clinica" class="text-emerald-300 hover:text-white transition-colors no-underline inline-flex items-center gap-2"><Icon name="lucide:map-pin" class="w-4 h-4" /> Nuestra clínica</a>
          </div>
        </div>

        <div>
          <h3 class="font-semibold text-white text-sm uppercase tracking-wider mb-4">Servicios</h3>
          <div class="flex flex-col gap-2 text-sm text-emerald-300">
            <a href="/servicios/eliminacion-amalgamas" class="hover:text-white transition-colors no-underline">Eliminación de amalgamas</a>
            <a href="/servicios/implantes-ceramicos" class="hover:text-white transition-colors no-underline">Implantes cerámicos</a>
            <a href="/servicios/odontologia-biomimetica" class="hover:text-
