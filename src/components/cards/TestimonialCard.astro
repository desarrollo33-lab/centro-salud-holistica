---
import { Icon } from "astro-icon/components";

interface Props {
  quote: string;
  author: string;
  location?: string;
  rating?: number;
}
const { quote, author, location, rating = 5 } = Astro.props;
---

<div class="bg-secondary-50 rounded-lg p-8">
  <div class="flex gap-1 text-secondary-500 mb-4">
    {Array.from({length: rating}).map(() => (
      <Icon name="lucide:star" class="w-5 h-5" aria-hidden="true" />
    ))}
  </div>
  <blockquote class="text-lg text-neutral-700 leading-relaxed italic">"{quote}"</blockquote>
  {author && (
    <div class="mt-5 flex items-center gap-3">
      <div class="w-10 h-10 rounded-full bg-primary-100 flex items-center justify-center shrink-0">
        <span class="text-primary-700 font-semibold text-sm">{author.charAt(0)}</span>
      </div>
      <div>
        <p class="font-semibold text-neutral-900 text-base">{author}</p>
        {location && <p class="text-sm text-neutral-500">{location}</p>}
      </div>
    </div>
  )}
</div>
