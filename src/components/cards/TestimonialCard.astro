---
import { Icon } from "astro-icon/components";

interface Props {
  quote: string;
  author: string;
  location?: string;
  rating?: number;
}
const { quote, author, location, rating = 5 } = Astro.props;
---

<div class="bg-white rounded-2xl p-8 border border-neutral-100 shadow-sm hover:shadow-lg hover:-translate-y-1 transition-all duration-300 group">
  <div class="flex gap-1 text-amber-400 mb-4">
    {Array.from({length: rating}).map(() => (
      <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 20 20"><path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/></svg>
    ))}
  </div>
  <Icon name="lucide:quote" class="w-8 h-8 text-primary-200 mb-3" />
  <blockquote class="text-base text-neutral-700 leading-relaxed">"{quote}"</blockquote>
  {author && (
    <div class="mt-5 flex items-center gap-3">
      <div class="w-10 h-10 rounded-full bg-primary-100 flex items-center justify-center shrink-0">
        <span class="text-primary-700 font-semibold text-sm">{author.charAt(0)}</span>
      </div>
      <div>
        <p class="font-semibold text-neutral-900 text-sm">{author}</p>
        {location && <p class="text-xs text-neutral-500">{location}</p>}
      </div>
    </div>
  )}
</div>
