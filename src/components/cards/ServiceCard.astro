---
import { Icon } from "astro-icon/components";

interface Props {
  name: string;
  slug: string;
  description: string;
  icon: string;
}
const { name, slug, description, icon } = Astro.props;
---

<a href={`/servicios/${slug}`} class="group block bg-white rounded-lg shadow-sm hover:shadow-md hover:-translate-y-4 transition-all duration-200 overflow-hidden relative">
  <div class="p-6">
    <div class="w-14 h-14 bg-primary-50 rounded-lg flex items-center justify-center mb-5 group-hover:bg-primary-600 transition-colors duration-200">
      <Icon name={icon} class="w-7 h-7 text-primary-600 group-hover:text-white transition-colors duration-200" />
    </div>
    <h3 class="text-xl font-semibold text-neutral-900 font-heading group-hover:text-primary-700 transition-colors duration-150">{name}</h3>
    <p class="mt-2 text-base text-neutral-600 line-clamp-2 leading-relaxed">{description}</p>
    <span class="mt-5 inline-flex items-center gap-1.5 text-accent font-medium text-base group-hover:gap-3 transition-all duration-200">
      Conocer más
      <Icon name="lucide:arrow-right" class="w-4 h-4 group-hover:translate-x-0.5 transition-transform duration-200" />
    </span>
  </div>
</a>
