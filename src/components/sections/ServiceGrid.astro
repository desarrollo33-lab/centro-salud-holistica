---
import ServiceCard from "../cards/ServiceCard.astro";
import type { Service } from "../../data/site";

interface Props {
  services: Service[];
  heading?: string;
  subtitle?: string;
}
const { services, heading, subtitle } = Astro.props;
---

<div>
  {heading && (
    <div class="text-center mb-12">
      <h2 class="text-3xl font-bold text-neutral-900 font-heading">{heading || "Nuestros Servicios"}</h2>
      {subtitle && <p class="mt-3 text-lg text-neutral-500 max-w-2xl mx-auto">{subtitle}</p>}
    </div>
  )}
  <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6">
    {services.map((svc) => (
      <ServiceCard name={svc.name} slug={svc.slug} description={svc.description} icon={svc.icon} />
    ))}
  </div>
</div>