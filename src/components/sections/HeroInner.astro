---
import Breadcrumbs from "../ui/Breadcrumbs.astro";

interface Props {
  title: string;
  subtitle?: string;
  breadcrumbs: { label: string; href: string }[];
}
const { title, subtitle, breadcrumbs } = Astro.props;
---

<section class="relative h-[260px] md:h-[320px] flex items-center overflow-hidden">
  <div class="absolute inset-0 bg-gradient-to-br from-primary-700 via-primary-800 to-neutral-900"></div>
  <div class="absolute inset-0 bg-[radial-gradient(ellipse_at_bottom_left,_var(--tw-gradient-stops))] from-secondary-600/10 via-transparent to-transparent"></div>

  <!-- Subtle animated elements -->
  <div class="absolute inset-0 pointer-events-none overflow-hidden" aria-hidden="true">
    <div class="hero-pattern-circle absolute top-[20%] right-[15%] w-56 h-56 rounded-full bg-secondary-400/5 blur-3xl"></div>
    <div class="absolute inset-0 opacity-[0.03]" style="background-image: radial-gradient(circle, white 1px, transparent 1px); background-size: 40px 40px;"></div>
    <svg class="hero-pattern-wave absolute bottom-0 left-0 w-full h-32 opacity-[0.05]" viewBox="0 0 1440 200" preserveAspectRatio="none">
      <path fill="none" stroke="white" stroke-width="1.5" d="M0,120 C360,180 720,60 1080,120 C1260,150 1380,100 1440,110"/>
    </svg>
  </div>

  <div class="relative max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 text-center w-full">
    <Breadcrumbs items={breadcrumbs} dark />
    <h1 class="animate-fade-in-up text-3xl md:text-4xl font-bold text-white font-heading mt-4 leading-tight">
      {title}
    </h1>
    {subtitle && (
      <p class="animate-fade-in-up mt-3 text-base md:text-lg text-white/80 max-w-2xl mx-auto" style="animation-delay: 0.1s">{subtitle}</p>
    )}
  </div>

  <!-- Bottom fade -->
  <div class="absolute bottom-0 left-0 right-0 h-16 bg-gradient-to-t from-neutral-50 to-transparent"></div>
</section>
