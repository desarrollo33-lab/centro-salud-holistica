---
import Breadcrumbs from "../ui/Breadcrumbs.astro";

interface Props {
  title: string;
  subtitle?: string;
  breadcrumbs: { label: string; href: string }[];
}
const { title, subtitle, breadcrumbs } = Astro.props;
---

<section class="relative h-[260px] md:h-[320px] flex items-center overflow-hidden">
  <div class="absolute inset-0 bg-gradient-to-br from-primary-700 via-primary-800 to-neutral-900"></div>

  <div class="relative max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 text-center w-full">
    <Breadcrumbs items={breadcrumbs} dark />
    <h1 class="text-3xl md:text-4xl font-bold text-white font-heading mt-4 leading-tight">
      {title}
    </h1>
    {subtitle && (
      <p class="mt-3 text-base md:text-lg text-white/80 max-w-2xl mx-auto">{subtitle}</p>
    )}
  </div>
</section>
