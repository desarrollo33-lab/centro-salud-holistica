---
import { Icon } from "astro-icon/components";
import Button from "../ui/Button.astro";
import { siteConfig } from "../../data/site";
---

<section data-hero class="relative min-h-[600px] lg:min-h-[85vh] flex items-center overflow-hidden">
  <!-- Gradient base -->
  <div class="absolute inset-0">
    <div class="absolute inset-0 bg-gradient-to-br from-primary-800 via-primary-700 to-neutral-900"></div>
    <div class="absolute inset-0 bg-[radial-gradient(ellipse_at_top_right,_var(--tw-gradient-stops))] from-secondary-600/20 via-transparent to-transparent"></div>
  </div>

  <!-- Animated SVG pattern -->
  <div class="absolute inset-0 pointer-events-none overflow-hidden" aria-hidden="true">
    <!-- Organic floating circles -->
    <div class="hero-pattern-circle absolute top-[15%] right-[10%] w-72 h-72 rounded-full bg-secondary-400/5 blur-3xl"></div>
    <div class="hero-pattern-circle absolute bottom-[20%] left-[5%] w-96 h-96 rounded-full bg-primary-400/8 blur-3xl"></div>
    <div class="hero-pattern-circle absolute top-[50%] right-[30%] w-48 h-48 rounded-full bg-white/3 blur-2xl"></div>

    <!-- Subtle wave lines -->
    <svg class="hero-pattern-wave absolute bottom-0 left-0 w-full h-48 opacity-[0.06]" viewBox="0 0 1440 200" preserveAspectRatio="none">
      <path fill="none" stroke="white" stroke-width="1.5" d="M0,120 C360,180 720,60 1080,120 C1260,150 1380,100 1440,110"/>
    </svg>
    <svg class="hero-pattern-wave absolute bottom-4 left-0 w-full h-40 opacity-[0.04]" viewBox="0 0 1440 200" preserveAspectRatio="none">
      <path fill="none" stroke="white" stroke-width="1" d="M0,160 C240,100 480,180 720,120 C960,60 1200,160 1440,100"/>
    </svg>

    <!-- Dot grid -->
    <div class="absolute inset-0 opacity-[0.03]" style="background-image: radial-gradient(circle, white 1px, transparent 1px); background-size: 40px 40px;"></div>

    <!-- Leaf / organic shapes -->
    <svg class="absolute top-[10%] right-[15%] w-24 h-24 opacity-[0.08]" viewBox="0 0 100 100" fill="none">
      <path d="M50 5 C90 20, 95 70, 50 95 C5 70, 10 20, 50 5Z" fill="white"/>
    </svg>
    <svg class="animate-float-delay absolute bottom-[25%] right-[8%] w-16 h-16 opacity-[0.06]" viewBox="0 0 100 100" fill="none">
      <path d="M50 5 C90 20, 95 70, 50 95 C5 70, 10 20, 50 5Z" fill="white"/>
    </svg>
    <svg class="animate-float absolute top-[30%] left-[3%] w-12 h-12 opacity-[0.05]" viewBox="0 0 100 100" fill="none">
      <circle cx="50" cy="50" r="45" stroke="white" stroke-width="2"/>
    </svg>
  </div>

  <div class="relative max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-20">
    <div class="max-w-2xl">
      <div class="animate-fade-in-up">
        <div class="inline-flex items-center gap-2 bg-white/10 backdrop-blur-sm border border-white/20 rounded-full px-4 py-2 mb-8">
          <span class="w-2 h-2 bg-secondary-400 rounded-full animate-pulse"></span>
          <span class="text-sm text-white/90 font-medium">Centro pionero de salud holística en Chile</span>
        </div>
      </div>

      <h1 class="animate-fade-in-up font-heading font-bold text-4xl lg:text-6xl text-white leading-tight" style="animation-delay: 0.1s">
        Belleza es habitarte<br />
        <span class="text-secondary-400">en armonía</span>
      </h1>

      <p class="animate-fade-in-up mt-6 text-xl text-white/80 max-w-lg" style="animation-delay: 0.2s">
        Odontología libre de metales pesados, implantes cerámicos biocompatibles y un enfoque que considera tu cuerpo, tu mente y tu vida.
      </p>

      <div class="animate-fade-in-up mt-8 flex flex-wrap gap-4" style="animation-delay: 0.3s">
        <Button href="/contacto" variant="white" size="lg">Agendar mi primera consulta</Button>
        <Button href="/libro" variant="ghost" size="lg" class="text-white hover:bg-white/10 border border-white/30 inline-flex items-center gap-2">
          <Icon name="lucide:book-open" class="w-5 h-5" /> Leer el libro gratuito
        </Button>
      </div>

      <div class="animate-fade-in-up mt-10 flex items-center gap-3" style="animation-delay: 0.4s">
        <div class="flex gap-1">
          {Array.from({length:5}).map(() => (
            <svg class="w-5 h-5 text-secondary-400" fill="currentColor" viewBox="0 0 20 20"><path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/></svg>
          ))}
        </div>
        <span class="text-white/80 text-sm font-medium">
          {siteConfig.stats.yearsOfExperience}+ años de experiencia · {siteConfig.stats.patientsTreated} pacientes atendidos
        </span>
      </div>
    </div>
  </div>

  <!-- Bottom gradient fade into content -->
  <div class="absolute bottom-0 left-0 right-0 h-24 bg-gradient-to-t from-neutral-50 to-transparent"></div>
</section>
