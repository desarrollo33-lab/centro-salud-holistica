---
import { Icon } from "astro-icon/components";
import Button from "../ui/Button.astro";
import Container from "../ui/Container.astro";
import { siteConfig } from "../../data/site";
---

<section data-hero class="relative min-h-[600px] lg:min-h-[85vh] flex items-start overflow-hidden">
  <div class="absolute inset-0">
    <img
      src="/images/hero-home.webp"
      alt="Costa de Chiloé, sur de Chile — conexión con la naturaleza y salud evolutiva"
      class="absolute inset-0 w-full h-full object-cover scale-105 origin-center"
      loading="eager"
      decoding="async"
    />
    <div class="absolute inset-0 bg-gradient-to-r from-black/60 via-black/30 to-transparent"></div>
  </div>

  <Container class="relative pt-20 lg:pt-28">
    <div class="max-w-2xl">
      <div class="inline-flex items-center gap-2 bg-white/15 backdrop-blur-sm border border-white/20 rounded-full px-4 py-2 mb-8">
        <span class="w-2 h-2 bg-secondary-400 rounded-full animate-pulse"></span>
        <span class="text-sm text-white/90 font-medium">Centro pionero de salud holística en Chile</span>
      </div>

      <h1 class="font-heading font-bold text-4xl lg:text-6xl text-white leading-tight">
        Belleza es habitarte<br />
        <span class="text-secondary-400">en armonía</span>
      </h1>

      <p class="mt-6 text-xl text-white/90 max-w-lg">
        Odontología libre de metales pesados, implantes cerámicos biocompatibles y un enfoque que considera tu cuerpo, tu mente y tu vida.
      </p>

      <div class="mt-8 flex flex-wrap gap-4">
        <Button href="/contacto" variant="white" size="lg">Agendar mi primera consulta</Button>
        <Button href="/libro" variant="ghost" size="lg" class="text-white hover:bg-white/10">
          <Icon name="lucide:book-open" class="w-5 h-5" /> Leer el libro gratuito
        </Button>
      </div>

      <div class="mt-10 flex items-center gap-3">
        <div class="flex gap-1">
          {Array.from({length:5}).map(() => (
            <svg class="w-5 h-5 text-secondary-400" fill="currentColor" viewBox="0 0 20 20"><path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/></svg>
          ))}
        </div>
        <span class="text-white/80 text-sm font-medium">
          {siteConfig.stats.yearsOfExperience}+ años de experiencia · {siteConfig.stats.patientsTreated} pacientes atendidos
        </span>
      </div>
    </div>
  </Container>
</section>
