---
import { Icon } from "astro-icon/components";
import Button from "../ui/Button.astro";
import { siteConfig } from "../../data/site";

interface Props {
  heading?: string;
  subtitle?: string;
  showPhone?: boolean;
}

const {
  heading = "¿Quieres empezar tu tratamiento?",
  subtitle = "Agenda tu primera consulta. Sin compromiso. Te escuchamos, evaluamos y te presentamos las opciones antes de proponer cualquier tratamiento.",
  showPhone = true,
} = Astro.props;
---

<section class="relative bg-gradient-to-r from-primary-700 via-primary-600 to-secondary-600 py-16 md:py-20 overflow-hidden">
  <!-- Subtle pattern -->
  <div class="absolute inset-0 pointer-events-none" aria-hidden="true">
    <div class="absolute inset-0 opacity-[0.04]" style="background-image: radial-gradient(circle, white 1px, transparent 1px); background-size: 32px 32px;"></div>
    <div class="absolute -top-20 -right-20 w-80 h-80 rounded-full bg-white/5 blur-3xl"></div>
    <div class="absolute -bottom-20 -left-20 w-60 h-60 rounded-full bg-white/5 blur-3xl"></div>
  </div>

  <div class="relative max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
    <h2 class="text-3xl font-bold text-white font-heading">{heading}</h2>
    <p class="mt-4 text-lg text-white/80 max-w-xl mx-auto">{subtitle}</p>
    <div class="mt-8 flex flex-wrap justify-center gap-4">
      <Button href="/contacto" variant="white" size="lg" class="inline-flex items-center gap-2">
        Agendar mi consulta <Icon name="lucide:arrow-right" class="w-5 h-5" />
      </Button>
      {showPhone && (
        <Button href={`tel:${siteConfig.phoneTel}`} variant="outline" size="lg" class="border-white text-white hover:bg-white hover:text-primary-600">
          Llamar {siteConfig.phone}
        </Button>
      )}
    </div>
  </div>
</section>
