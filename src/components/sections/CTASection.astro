---
import { Icon } from "astro-icon/components";
import Button from "../ui/Button.astro";
import Section from "../ui/Section.astro";
import Container from "../ui/Container.astro";
import { siteConfig } from "../../data/site";

interface Props {
  heading?: string;
  subtitle?: string;
  showPhone?: boolean;
}

const {
  heading = "¿Quieres empezar tu tratamiento?",
  subtitle = "Agenda tu primera consulta. Sin compromiso. Te escuchamos, evaluamos y te presentamos las opciones antes de proponer cualquier tratamiento.",
  showPhone = true,
} = Astro.props;
---

<Section class="bg-gradient-to-r from-primary-700 via-primary-600 to-secondary-600">
  <Container class="text-center">
    <h2 class="text-3xl font-bold text-white font-heading">{heading}</h2>
    <p class="mt-4 text-lg text-white/80 max-w-xl mx-auto">{subtitle}</p>
    <div class="mt-8 flex flex-wrap justify-center gap-4">
      <Button href="/contacto" variant="white" size="lg">
        Agendar mi consulta <Icon name="lucide:arrow-right" class="w-5 h-5" />
      </Button>
      {showPhone && (
        <Button href={`tel:${siteConfig.phoneTel}`} variant="outline-white" size="lg">
          Llamar {siteConfig.phone}
        </Button>
      )}
    </div>
  </Container>
</Section>
