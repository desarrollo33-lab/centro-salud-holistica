---
import { Icon } from "astro-icon/components";
import { siteConfig } from "../data/site";
import { services } from "../data/site";
---

<footer class="bg-neutral-900 text-neutral-300 relative overflow-hidden">
  <!-- Subtle top decoration -->
  <div class="absolute top-0 left-0 right-0 h-1 bg-gradient-to-r from-primary-500 via-secondary-400 to-primary-500"></div>
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 pt-24 pb-12">
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-10">
      <div>
        <a href="/" class="flex items-center gap-2 mb-4 no-underline">
          <img src="/images/logo.webp" alt="Logo" class="h-14 w-auto" />
          <div>
            <span class="font-heading font-bold text-sm text-white block">Centro de Salud</span>
            <span class="font-heading text-xs text-neutral-400 block">Evolutiva</span>
          </div>
        </a>
        <p class="text-sm text-neutral-400 leading-relaxed">
          Odontología biológica y holística en Santiago. Cuidamos tu salud bucal en armonía con tu cuerpo y tu vida. Libre de mercurio, sin metales pesados.
        </p>
        <div class="flex gap-4 mt-6">
          <a href={siteConfig.social.instagram} class="text-neutral-400 hover:text-primary-400 transition-colors" aria-label="Instagram">
            <Icon name="lucide:instagram" class="w-5 h-5" aria-hidden="true" />
          </a>
          <a href={siteConfig.social.facebook} class="text-neutral-400 hover:text-primary-400 transition-colors" aria-label="Facebook">
            <Icon name="lucide:facebook" class="w-5 h-5" aria-hidden="true" />
          </a>
          <a href={siteConfig.social.youtube} class="text-neutral-400 hover:text-primary-400 transition-colors" aria-label="YouTube">
            <Icon name="lucide:youtube" class="w-5 h-5" aria-hidden="true" />
          </a>
        </div>
      </div>

      <div>
        <h3 class="font-heading font-semibold text-white text-lg mb-4">Servicios</h3>
        <ul class="space-y-2">
          {services.slice(0,6).map((svc) => (
            <li>
              <a href={`/servicios/${svc.slug}`} class="text-sm text-neutral-300 hover:text-primary-400 transition-colors no-underline inline-flex items-center gap-2">
                <Icon name={svc.icon} class="w-4 h-4 text-primary-400 shrink-0" aria-hidden="true" />
                {svc.name}
              </a>
            </li>
          ))}
          <li>
            <a href="/servicios" class="text-sm text-neutral-300 hover:text-primary-400 transition-colors no-underline inline-flex items-center gap-1">
              Ver todos <Icon name="lucide:arrow-right" class="w-3.5 h-3.5" aria-hidden="true" />
            </a>
          </li>
        </ul>
      </div>

      <div>
        <h3 class="font-heading font-semibold text-white text-lg mb-4">Navegación</h3>
        <ul class="space-y-2">
          <li><a href="/libro" class="text-sm text-neutral-300 hover:text-primary-400 transition-colors no-underline inline-flex items-center gap-2"><Icon name="lucide:book-open" class="w-4 h-4 text-primary-400 shrink-0" aria-hidden="true" /> Libro gratuito</a></li>
          <li><a href="/aprende" class="text-sm text-neutral-300 hover:text-primary-400 transition-colors no-underline inline-flex items-center gap-2"><Icon name="lucide:graduation-cap" class="w-4 h-4 text-primary-400 shrink-0" aria-hidden="true" /> Aprende</a></li>
          <li><a href="/sobre" class="text-sm text-neutral-300 hover:text-primary-400 transition-colors no-underline inline-flex items-center gap-2"><Icon name="lucide:user-round" class="w-4 h-4 text-primary-400 shrink-0" aria-hidden="true" /> Doctor</a></li>
          <li><a href="/clinica" class="text-sm text-neutral-300 hover:text-primary-400 transition-colors no-underline inline-flex items-center gap-2"><Icon name="lucide:map-pin" class="w-4 h-4 text-primary-400 shrink-0" aria-hidden="true" /> Clínica</a></li>
          <li><a href="/internacional" class="text-sm text-neutral-300 hover:text-primary-400 transition-colors no-underline inline-flex items-center gap-2"><Icon name="lucide:globe-2" class="w-4 h-4 text-primary-400 shrink-0" aria-hidden="true" /> Internacionales</a></li>
          <li><a href="/sintomas" class="text-sm text-neutral-300 hover:text-primary-400 transition-colors no-underline inline-flex items-center gap-2"><Icon name="lucide:search" class="w-4 h-4 text-primary-400 shrink-0" aria-hidden="true" /> Síntomas</a></li>
          <li><a href="/glosario" class="text-sm text-neutral-300 hover:text-primary-400 transition-colors no-underline inline-flex items-center gap-2"><Icon name="lucide:book-text" class="w-4 h-4 text-primary-400 shrink-0" aria-hidden="true" /> Glosario</a></li>
          <li><a href="/blog" class="text-sm text-neutral-300 hover:text-primary-400 transition-colors no-underline inline-flex items-center gap-2"><Icon name="lucide:newspaper" class="w-4 h-4 text-primary-400 shrink-0" aria-hidden="true" /> Blog</a></li>
        </ul>
      </div>

      <div>
        <h3 class="font-heading font-semibold text-white text-lg mb-4">Contacto</h3>
        <ul class="space-y-3 text-sm">
          <li class="flex items-start gap-3">
            <Icon name="lucide:map-pin" class="w-5 h-5 text-primary-400 mt-0.5 shrink-0" aria-hidden="true" />
            <span>{siteConfig.address.street}<br />{siteConfig.address.city}, {siteConfig.address.state}</span>
          </li>
          <li class="flex items-start gap-3">
            <Icon name="lucide:phone" class="w-5 h-5 text-primary-400 mt-0.5 shrink-0" aria-hidden="true" />
            <a href={`tel:${siteConfig.phoneTel}`} class="text-neutral-300 hover:text-primary-400 transition-colors">{siteConfig.phone}</a>
          </li>
          <li class="flex items-start gap-3">
            <Icon name="lucide:mail" class="w-5 h-5 text-primary-400 mt-0.5 shrink-0" aria-hidden="true" />
            <a href={`mailto:${siteConfig.email}`} class="text-neutral-300 hover:text-primary-400 transition-colors break-all">{siteConfig.email}</a>
          </li>
          <li class="flex items-start gap-3">
            <Icon name="lucide:clock" class="w-5 h-5 text-primary-400 mt-0.5 shrink-0" aria-hidden="true" />
            <span>Lun-Vie: 9:00 AM - 6:00 PM<br />Sáb-Dom: Cerrado</span>
          </li>
        </ul>
      </div>
    </div>

    <div class="border-t border-neutral-800 mt-12 pt-6 flex flex-col sm:flex-row items-center justify-between gap-4">
      <p class="text-sm text-neutral-500">© {new Date().getFullYear()} {siteConfig.name}. Todos los derechos reservados.</p>
      <p class="text-xs text-neutral-600">Contenido con fines educativos. No sustituye el consejo profesional.</p>
    </div>
  </div>
</footer>
