---
interface Props {
  items: { label: string; href: string }[];
  dark?: boolean;
}
const { items, dark = false } = Astro.props;
---
<nav aria-label="Breadcrumb">
  <ol class="flex items-center gap-2 text-sm flex-wrap">
    {items.map((item, index) => (
      <li class="flex items-center gap-2">
        {index > 0 && (
          <svg class:list={["w-4 h-4", dark ? "text-white/50" : "text-neutral-400"]} fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/>
          </svg>
        )}
        {index === items.length - 1 ? (
          <span class:list={[dark ? "text-white/90 font-medium" : "text-neutral-700 font-medium"]}>{item.label}</span>
        ) : (
          <a href={item.href} class:list={[dark ? "text-white/70 hover:text-white" : "text-neutral-500 hover:text-primary-600", "transition-colors"]}>{item.label}</a>
        )}
      </li>
    ))}
  </ol>
</nav>