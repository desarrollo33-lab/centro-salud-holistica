---
import Layout from '../../Layout.astro';
---

<Layout title="Iniciar Sesión | Centro de Salud Holística">
  <main class="min-h-screen bg-gray-50 py-12">
    <div class="max-w-md mx-auto px-4">
      <div class="text-center mb-8">
        <h1 class="text-3xl font-serif text-gray-900 mb-2">Bienvenido</h1>
        <p class="text-gray-600">Accede a tu cuenta para continuar tu camino hacia la salud evolutiva</p>
      </div>

      <div id="error" class="hidden bg-red-50 border border-red-200 text-red-700 px-4 py-3 rounded-lg mb-6"></div>

      <form id="login-form" class="bg-white shadow-lg rounded-xl p-8">
        <div class="space-y-6">
          <div>
            <label for="email" class="block text-sm font-medium text-gray-700 mb-2">Correo Electrónico</label>
            <input type="email" id="email" name="email" required class="w-full px-4 py-3 border border-gray-300 rounded-lg focus:ring-2 focus:ring-teal-500 outline-none" placeholder="tu@email.com" />
          </div>
          <div>
            <label for="password" class="block text-sm font-medium text-gray-700 mb-2">Contraseña</label>
            <input type="password" id="password" name="password" required class="w-full px-4 py-3 border border-gray-300 rounded-lg focus:ring-2 focus:ring-teal-500 outline-none" placeholder="Tu contraseña" />
          </div>
          <button type="submit" id="submit-btn" class="w-full bg-teal-700 text-white py-3 px-6 rounded-lg font-medium hover:bg-teal-800">Iniciar Sesión</button>
        </div>
      </form>

      <p class="text-center mt-6 text-gray-600">¿No tienes cuenta? <a href="/auth/registro/" class="text-teal-700 hover:text-teal-800 font-medium">Regístrate aquí</a></p>
    </div>
  </main>

  <script>
    import PocketBase from 'pocketbase';
    const form = document.getElementById('login-form');
    const errorDiv = document.getElementById('error');
    const submitBtn = document.getElementById('submit-btn');

    form?.addEventListener('submit', async (e) => {
      e.preventDefault();
      const email = (document.getElementById('email') as HTMLInputElement).value;
      const password = (document.getElementById('password') as HTMLInputElement).value;
      if (submitBtn) submitBtn.textContent = 'Cargando...';
      if (errorDiv) errorDiv.classList.add('hidden');

      try {
        const pb = new PocketBase('http://64.176.16.231:8090');
        await pb.collection('users').authWithPassword(email, password);
        window.location.href = '/mi-cuenta/';
      } catch (err) {
        if (errorDiv) { errorDiv.textContent = 'Credenciales inválidas.'; errorDiv.classList.remove('hidden'); }
        if (submitBtn) submitBtn.textContent = 'Iniciar Sesión';
      }
    });
  </script>
</Layout>
