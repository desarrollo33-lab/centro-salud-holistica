---
import BaseLayout from "../../layouts/BaseLayout.astro";
import Section from "../../components/ui/Section.astro";
import Container from "../../components/ui/Container.astro";
---

<BaseLayout
  title="Iniciar Sesión | Centro de Salud Holística"
  description="Accede a tu cuenta del Centro de Salud Holística del Dr. Ipinza."
  noindex={true}
>
  <Section>
    <Container>
      <div class="max-w-md mx-auto">
        <div class="text-center mb-8">
          <h1 class="text-3xl font-bold text-neutral-900 font-heading mb-2">Bienvenido</h1>
          <p class="text-neutral-600">Accede a tu cuenta para continuar tu camino hacia la salud evolutiva</p>
        </div>

        <div id="error" class="hidden bg-red-50 border border-red-200 text-red-700 px-4 py-3 rounded-lg mb-6"></div>

        <form id="login-form" class="bg-white rounded-lg shadow-sm p-8">
          <div class="space-y-6">
            <div>
              <label for="email" class="block text-sm font-medium text-neutral-700 mb-2">Correo Electrónico</label>
              <input type="email" id="email" name="email" required 
                class="w-full px-4 py-3 border border-neutral-200 rounded-md focus:ring-2 focus:ring-primary-500 focus:border-primary-500 outline-none transition-colors" 
                placeholder="tu@email.com" />
            </div>
            <div>
              <label for="password" class="block text-sm font-medium text-neutral-700 mb-2">Contraseña</label>
              <input type="password" id="password" name="password" required 
                class="w-full px-4 py-3 border border-neutral-200 rounded-md focus:ring-2 focus:ring-primary-500 focus:border-primary-500 outline-none transition-colors" 
                placeholder="Tu contraseña" />
            </div>
            <button type="submit" id="submit-btn" 
              class="w-full bg-primary-600 text-white py-3 px-6 rounded-lg font-semibold hover:bg-primary-700 transition-colors">
              Iniciar Sesión
            </button>
          </div>
        </form>

        <p class="text-center mt-6 text-neutral-600">
          ¿No tienes cuenta? <a href="/auth/registro/" class="text-primary-600 hover:text-primary-700 font-medium">Regístrate aquí</a>
        </p>
      </div>
    </Container>
  </Section>

  <script>
    const form = document.getElementById('login-form');
    const errorDiv = document.getElementById('error');
    const submitBtn = document.getElementById('submit-btn');

    form?.addEventListener('submit', async (e) => {
      e.preventDefault();
      const email = (document.getElementById('email') as HTMLInputElement).value;
      const password = (document.getElementById('password') as HTMLInputElement).value;
      
      if (submitBtn) { submitBtn.textContent = 'Cargando...'; submitBtn.setAttribute('disabled', 'true'); }
      if (errorDiv) { errorDiv.classList.add('hidden'); errorDiv.textContent = ''; }

      try {
        const response = await fetch('/api/auth/login', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ identity: email, password })
        });

        const data = await response.json();

        if (!response.ok) {
          throw new Error(data.error || 'Error al iniciar sesión');
        }

        localStorage.setItem('pb_auth', JSON.stringify({
          token: data.token,
          model: data.user
        }));

        const params = new URLSearchParams(window.location.search);
        const redirect = params.get('redirect') || '/mi-cuenta/';
        window.location.href = redirect;
      } catch (err: any) {
        console.error('Login error:', err);
        if (errorDiv) { errorDiv.textContent = err.message || 'Credenciales inválidas. Verifica tu email y contraseña.'; errorDiv.classList.remove('hidden'); }
        if (submitBtn) { submitBtn.textContent = 'Iniciar Sesión'; submitBtn.removeAttribute('disabled'); }
      }
    });
  </script>
</BaseLayout>
