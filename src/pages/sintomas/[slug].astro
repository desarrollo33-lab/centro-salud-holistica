---
import { Icon } from "astro-icon/components";
import BaseLayout from "../../layouts/BaseLayout.astro";
import HeroInner from "../../components/sections/HeroInner.astro";
import Section from "../../components/ui/Section.astro";
import Container from "../../components/ui/Container.astro";
import SchemaBreadcrumb from "../../components/seo/SchemaBreadcrumb.astro";
import SchemaFAQ from "../../components/seo/SchemaFAQ.astro";
import SchemaService from "../../components/seo/SchemaService.astro";
import { symptomPages } from "../../data/symptoms";
import { services, getServiceBySlug } from "../../data/site";

export function getStaticPaths() {
  return symptomPages.map((sp) => ({
    params: { slug: sp.slug },
    props: { page: sp },
  }));
}

const { page: sp } = Astro.props;
const relatedServices = sp.services
  .map((slug) => getServiceBySlug(slug))
  .filter(Boolean);
---

<BaseLayout
  title={`${sp.symptom} — Tratamiento en Santiago | Centro de Salud Holística`}
  description={sp.description}
>
  <HeroInner
    title={`${sp.symptom}: Tratamiento Biológico en Santiago`}
    subtitle={sp.description}
    breadcrumbs={[
      { label: "Inicio", href: "/" },
      { label: "Síntomas", href: "/sintomas" },
      { label: sp.symptom, href: `/sintomas/${sp.slug}` },
    ]}
  />

  <!-- Explanation -->
  <Section>
    <Container>
      <div class="max-w-3xl mx-auto">
        <h2 class="font-heading text-2xl font-bold text-neutral-900 mb-4">
          ¿Qué es y por qué ocurre?
        </h2>
        <p class="text-neutral-600 leading-relaxed">{sp.explanation}</p>
      </div>
    </Container>
  </Section>

  <!-- Treatment -->
  <Section bg="light">
    <Container>
      <div class="max-w-3xl mx-auto">
        <h2 class="font-heading text-2xl font-bold text-neutral-900 mb-4">
          ¿Cómo lo tratamos?
        </h2>
        <p class="text-neutral-600 leading-relaxed">{sp.treatment}</p>
      </div>
    </Container>
  </Section>

  <!-- Related Services -->
  <Section>
    <Container>
      <h2 class="font-heading text-2xl font-bold text-neutral-900 text-center mb-8">
        Servicios relacionados con {sp.symptom.toLowerCase()}
      </h2>
      <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-6 max-w-5xl mx-auto">
        {relatedServices.map((svc) => (
          <a
            href={`/servicios/${svc.slug}`}
            class="group block bg-white rounded-xl p-6 border border-neutral-200 hover:shadow-md hover:-translate-y-px transition-all duration-200 no-underline"
          >
            <div class="w-11 h-11 bg-primary-50 border border-primary-200 rounded-lg flex items-center justify-center mb-4 group-hover:bg-primary-600 group-hover:border-primary-600 transition-colors duration-200">
              <Icon name={svc.icon} class="w-5 h-5 text-primary-600 group-hover:text-white transition-colors duration-200" aria-hidden="true" />
            </div>
            <h3 class="font-heading font-semibold text-neutral-900 mb-1.5 group-hover:text-primary-700 transition-colors">
              {svc.name}
            </h3>
            <p class="text-sm text-neutral-500 leading-relaxed line-clamp-3">
              {svc.description}
            </p>
            <span class="inline-flex items-center gap-1.5 text-sm text-accent font-medium mt-3 group-hover:gap-2.5 transition-all duration-200">
              Conocer más
              <Icon name="lucide:arrow-right" class="w-4 h-4" aria-hidden="true" />
            </span>
          </a>
        ))}
      </div>
    </Container>
  </Section>

  <!-- Related Content -->
  {(sp.guide || sp.tool) && (
    <Section bg="light">
      <Container>
        <div class="max-w-3xl mx-auto">
          <h2 class="font-heading text-2xl font-bold text-neutral-900 mb-6">
            Aprende más
          </h2>
          <div class="grid sm:grid-cols-2 gap-4">
            {sp.guide && (
              <a
                href={`/aprende/${sp.guide}`}
                class="flex items-start gap-3 p-4 rounded-lg border border-neutral-200 hover:border-primary-300 hover:bg-primary-50/50 transition-all no-underline"
              >
                <div class="w-9 h-9 bg-primary-100 rounded-lg flex items-center justify-center shrink-0">
                  <Icon name="lucide:graduation-cap" class="w-4 h-4 text-primary-600" aria-hidden="true" />
                </div>
                <div>
                  <span class="text-sm font-medium text-neutral-900">Guía relacionada</span>
                  <p class="text-xs text-neutral-500 mt-0.5">Artículo educativo sobre este tema</p>
                </div>
              </a>
            )}
            {sp.tool && (
              <a
                href={`/recursos/${sp.tool}`}
                class="flex items-start gap-3 p-4 rounded-lg border border-neutral-200 hover:border-primary-300 hover:bg-primary-50/50 transition-all no-underline"
              >
                <div class="w-9 h-9 bg-primary-100 rounded-lg flex items-center justify-center shrink-0">
                  <Icon name="lucide:clipboard-list" class="w-4 h-4 text-primary-600" aria-hidden="true" />
                </div>
                <div>
                  <span class="text-sm font-medium text-neutral-900">Recurso práctico</span>
                  <p class="text-xs text-neutral-500 mt-0.5">Checklist o guía paso a paso</p>
                </div>
              </a>
            )}
          </div>
        </div>
      </Container>
    </Section>
  )}

  <!-- CTA -->
  <Section>
    <Container>
      <div class="max-w-2xl mx-auto text-center">
        <h2 class="font-heading text-2xl font-bold text-neutral-900 mb-4">
          {sp.cta}
        </h2>
        <p class="text-neutral-600 mb-8">
          La primera consulta es sin compromiso. Te escuchamos, evaluamos y te presentamos las opciones.
        </p>
        <div class="flex flex-wrap justify-center gap-4">
          <a
            href="/contacto"
            class="inline-flex items-center gap-2 bg-primary-600 text-white font-semibold px-6 py-3 rounded-md hover:bg-primary-700 transition-colors no-underline"
          >
            Agendar consulta
            <Icon name="lucide:arrow-right" class="w-5 h-5" aria-hidden="true" />
          </a>
          <a
            href="https://wa.me/569XXXXXXXX"
            class="inline-flex items-center gap-2 bg-white border border-neutral-200 text-neutral-700 font-semibold px-6 py-3 rounded-md hover:bg-neutral-50 transition-colors no-underline"
            target="_blank"
            rel="noopener"
          >
            <Icon name="lucide:message-circle" class="w-5 h-5" aria-hidden="true" />
            WhatsApp
          </a>
        </div>
      </div>
    </Container>
  </Section>

  <!-- Schemas -->
  <SchemaBreadcrumb
    items={[
      { name: "Inicio", url: "/" },
      { name: "Síntomas", url: "/sintomas" },
      { name: sp.symptom, url: `/sintomas/${sp.slug}` },
    ]}
  />
  {relatedServices.map((svc) => (
    <SchemaService
      serviceName={svc.name}
      serviceDescription={svc.description}
      priceRange={svc.priceRange}
    />
  ))}
  <SchemaFAQ faqs={sp.faqs} />
</BaseLayout>
