---
import { Icon } from "astro-icon/components";
import BaseLayout from "../layouts/BaseLayout.astro";
import HeroInner from "../components/sections/HeroInner.astro";
import Section from "../components/ui/Section.astro";
import Container from "../components/ui/Container.astro";
import { siteConfig } from "../data/site";
---

<BaseLayout
  title="Contacto — Centro de Salud Holística"
  description="Agenda tu hora con el Dr. Joaquín Ipinza. Evaluación sin compromiso. Los Dominicos, Las Condes, Santiago."
>
  <HeroInner
    title="Agenda tu consulta"
    subtitle="La primera consulta es sin compromiso. Te escuchamos, evaluamos y te presentamos las opciones."
    breadcrumbs={[{ label: "Inicio", href: "/" }, { label: "Contacto", href: "/contacto" }]}
  />

  <Section>
    <Container>
      <div class="grid lg:grid-cols-3 gap-12">
        <div class="lg:col-span-2">
          <form class="bg-white rounded-lg border border-neutral-200 p-8 shadow-sm" onsubmit="event.preventDefault(); const btn=this.querySelector('.submit-btn'); const msg=this.querySelector('.form-msg'); btn.innerHTML='<span class=\'inline-flex items-center gap-2\'><svg class=\'animate-spin w-4 h-4\' viewBox=\'0 0 24 24\'><circle class=\'opacity-25\' cx=\'12\' cy=\'12\' r=\'10\' stroke=\'currentColor\' stroke-width=\'4\' fill=\'none\'/><path class=\'opacity-75\' fill=\'currentColor\' d=\'M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4z\'/></svg> Enviando...</span>'; btn.disabled=true; setTimeout(()=>{btn.innerHTML='<span class=\'inline-flex items-center gap-2\'><svg class=\'w-4 h-4\' fill=\'none\' stroke=\'currentColor\' viewBox=\'0 0 24 24\'><path stroke-linecap=\'round\' stroke-linejoin=\'round\' stroke-width=\'2\' d=\'M5 13l4 4L19 7\'/></svg> Enviado</span>'; btn.classList.add('bg-success'); if(msg)msg.textContent='Tu mensaje fue enviado. Te contactaremos en 24-48 horas.';},800);">
            <div class="space-y-5">
              <div>
                <label class="block text-sm font-medium text-neutral-700 mb-1.5">Nombre completo *</label>
                <input type="text" required placeholder="Tu nombre" class="w-full px-4 py-3 border border-neutral-200 rounded-lg focus:ring-2 focus:ring-primary-600 focus:border-primary-600 outline-none transition" />
              </div>
              <div class="grid sm:grid-cols-2 gap-4">
                <div>
                  <label class="block text-sm font-medium text-neutral-700 mb-1.5">Email *</label>
                  <input type="email" required placeholder="tu@email.com" class="w-full px-4 py-3 border border-neutral-200 rounded-lg focus:ring-2 focus:ring-primary-600 focus:border-primary-600 outline-none transition" />
                </div>
                <div>
                  <label class="block text-sm font-medium text-neutral-700 mb-1.5">Teléfono / WhatsApp</label>
                  <input type="tel" placeholder="+56 9 XXXX XXXX" class="w-full px-4 py-3 border border-neutral-200 rounded-lg focus:ring-2 focus:ring-primary-600 focus:border-primary-600 outline-none transition" />
                </div>
              </div>
              <div>
                <label class="block text-sm font-medium text-neutral-700 mb-1.5">País</label>
                <select class="w-full px-4 py-3 border border-neutral-200 rounded-lg focus:ring-2 focus:ring-primary-600 focus:border-primary-600 outline-none transition bg-white">
                  <option value="">Selecciona tu país</option>
                  <option>Chile</option><option>Argentina</option><option>Peru</option><option>Mexico</option><option>Colombia</option><option>España</option><option>Otro</option>
                </select>
              </div>
              <div>
                <label class="block text-sm font-medium text-neutral-700 mb-1.5">¿Qué te interesa?</label>
                <select class="w-full px-4 py-3 border border-neutral-200 rounded-lg focus:ring-2 focus:ring-primary-600 focus:border-primary-600 outline-none transition bg-white">
                  <option value="">Selecciona un servicio</option>
                  <option>Eliminación de amalgamas</option>
                  <option>Implantes cerámicos</option>
                  <option>Odontología biomimética</option>
                  <option>Tratamiento de ATM</option>
                  <option>Revisión / Segunda opinión</option>
                  <option>Otro tratamiento</option>
                  <option>Solo información</option>
                </select>
              </div>
              <div>
                <label class="block text-sm font-medium text-neutral-700 mb-1.5">Cuéntanos brevemente tu situación</label>
                <textarea rows="4" placeholder="¿Cuánto tiempo llevas con el problema? ¿Qué tratamientos has tenido? ¿Cuál es tu pregunta principal?" class="w-full px-4 py-3 border border-neutral-200 rounded-lg focus:ring-2 focus:ring-primary-600 focus:border-primary-600 outline-none transition resize-none"></textarea>
              </div>
              <button type="submit" class="submit-btn w-full bg-primary-600 text-white font-semibold py-3 rounded-md hover:bg-primary-700 transition-colors inline-flex items-center justify-center gap-2">
                Enviar mensaje <Icon name="lucide:arrow-right" class="w-4 h-4" />
              </button>
              <p class="form-msg text-sm text-primary-600 font-medium text-center mt-2 hidden"></p>
              <p class="text-xs text-neutral-400 text-center">Te respondemos en 24-48 horas hábiles.</p>
            </div>
          </form>
        </div>

        <div class="space-y-5">
          <div class="bg-white rounded-lg p-6 shadow-sm">
            <h3 class="font-heading font-semibold text-neutral-900 mb-4 inline-flex items-center gap-2">
              <Icon name="lucide:map-pin" class="w-5 h-5 text-primary-500" /> Clínica
            </h3>
            <p class="text-neutral-600 text-sm leading-relaxed">
              Los Dominicos, Las Condes<br />
              Santiago, Chile<br /><br />
              <a href="/clinica" class="text-primary-600 hover:underline no-underline inline-flex items-center gap-1">
                Ver cómo llegar <Icon name="lucide:arrow-right" class="w-3.5 h-3.5" />
              </a>
            </p>
          </div>
          <div class="bg-white rounded-lg p-6 shadow-sm">
            <h3 class="font-heading font-semibold text-neutral-900 mb-4 inline-flex items-center gap-2">
              <Icon name="lucide:phone" class="w-5 h-5 text-primary-500" /> Teléfono
            </h3>
            <p class="text-neutral-600 text-sm">{siteConfig.phone}</p>
            <p class="text-neutral-500 text-sm mt-1">WhatsApp disponible</p>
          </div>
          <div class="bg-white rounded-lg p-6 shadow-sm">
            <h3 class="font-heading font-semibold text-neutral-900 mb-4 inline-flex items-center gap-2">
              <Icon name="lucide:mail" class="w-5 h-5 text-primary-500" /> Email
            </h3>
            <a href={`mailto:${siteConfig.email}`} class="text-primary-600 text-sm hover:underline no-underline break-all">{siteConfig.email}</a>
          </div>
          <div class="bg-white rounded-lg p-6 shadow-sm">
            <h3 class="font-heading font-semibold text-neutral-900 mb-4 inline-flex items-center gap-2">
              <Icon name="lucide:clock" class="w-5 h-5 text-primary-500" /> Horarios
            </h3>
            <p class="text-neutral-600 text-sm leading-relaxed">
              Lunes a Viernes<br />9:00 AM — 6:00 PM<br /><br />
              <span class="text-neutral-400">Sábados y Domingos: Cerrado</span>
            </p>
          </div>
        </div>
      </div>
    </Container>
  </Section>
</BaseLayout>
