---
import { Icon } from "astro-icon/components";
import BaseLayout from "../../layouts/BaseLayout.astro";
import HeroInner from "../../components/sections/HeroInner.astro";
import Section from "../../components/ui/Section.astro";
import Container from "../../components/ui/Container.astro";
---

<BaseLayout title="Guías Prácticas — Salud Evolutiva" description="Artículos educativos basados en el libro Salud Evolutiva. Escritos para que cualquier persona pueda entender y aplicar.">
  <HeroInner title="Guías Prácticas" subtitle="Artículos educativos para entender y aplicar los conocimientos del Dr. Ipinza" breadcrumbs={[{ label: "Inicio", href: "/" }, { label: "Aprende", href: "/aprende" }]} />
  <Section>
    <Container>
      <div class="max-w-3xl mx-auto">
        <div class="space-y-4">
          {[
            { slug: "vitamina-k2-guia-completa", topic: "Nutricion", title: "Vitamina K2: La guia completa para tu salud dental y general", desc: "Que es, por que la necesitas, como obterla y su relacion con tus dientes." },
            { slug: "caries-prevencion-natural", topic: "Prevencion", title: "Caries: causas reales, prevencion natural y lo que dice la ciencia", desc: "Mas alla del azucar: por que tenemos caries y como prevenirlas." },
            { slug: "enfermedad-periodontal-guia", topic: "Encias", title: "Enfermedad periodontal: la conexion entre tus encias y tu salud general", desc: "Que es, como detectarla a tiempo, y su vinculo con diabetes y corazon." },
            { slug: "estres-y-salud-dental", topic: "Bienestar", title: "Estres y salud dental: la conexion que nadie te conto", desc: "Como el estres cronico destruye tus encias, causa bruxismo y afecta tu boca." },
            { slug: "nutricion-para-dientes-sanos", topic: "Alimentacion", title: "Nutricion para dientes sanos: que comer segun la ciencia evolutiva", desc: "Vitamina K2, vitamina D y los alimentos que protegen tu boca." },
          ].map((guide) => (
            <a href={`/aprende/${guide.slug}`} class="group block bg-white rounded-lg p-6 shadow-sm hover:shadow-md transition-all duration-200 no-underline">
              <div class="flex items-start justify-between gap-4">
                <div>
                  <span class="badge-guide text-xs">{guide.topic}</span>
                  <h2 class="font-heading font-semibold text-lg text-neutral-900 mt-2 group-hover:text-primary-700 transition-colors">{guide.title}</h2>
                  <p class="text-neutral-500 mt-1 text-sm leading-relaxed">{guide.desc}</p>
                </div>
                <Icon name="lucide:arrow-right" class="w-4 h-4 text-neutral-300 shrink-0 mt-6 group-hover:text-primary-500 group-hover:translate-x-1 transition-all" />
              </div>
            </a>
          ))}
        </div>
      </div>
    </Container>
  </Section>
</BaseLayout>
