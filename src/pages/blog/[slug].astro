---
import { Icon } from "astro-icon/components";
import BaseLayout from '../../layouts/BaseLayout.astro';
import { pb } from '../../lib/pocketbase';
import { marked } from 'marked';
import SchemaBreadcrumb from '../../components/seo/SchemaBreadcrumb.astro';
import SchemaArticle from '../../components/seo/SchemaArticle.astro';
import Breadcrumbs from '../../components/ui/Breadcrumbs.astro';
import RelatedServices from '../../components/sections/RelatedServices.astro';

export async function getStaticPaths() {
  try {
    const records = await pb.collection('blog').getList(1, 50, {
      filter: 'status="published"',
      sort: '-published_at'
    });
    
    return records.items.map((post) => ({
      params: { slug: post.slug },
      props: { post }
    }));
  } catch (e) {
    console.error('Error fetching blog posts:', e);
    return [];
  }
}

const { post } = Astro.props;

function renderMarkdown(text: string): string {
  if (!text) return '';
  return marked.parse(text, { async: false }) as string;
}
---

<BaseLayout
  title={post ? `${post.title} | Blog` : 'Artículo no encontrado'}
  description={post?.excerpt || 'Artículo del blog del Dr. Ipinza'}
>
  {!post && (
    <div class="min-h-[60vh] flex items-center justify-center">
      <div class="text-center">
        <Icon name="lucide:file-text" class="w-14 h-14 text-neutral-300 mx-auto mb-4"  aria-hidden="true"/>
        <h1 class="text-2xl font-bold text-neutral-900 font-heading mb-4">Artículo no encontrado</h1>
        <a href="/blog" class="text-primary-600 hover:text-primary-700 font-medium inline-flex items-center gap-1">
          <Icon name="lucide:arrow-left" class="w-4 h-4"  aria-hidden="true"/> Volver al blog
        </a>
      </div>
    </div>
  )}

  {post && (
    <article>
      <header class="bg-primary-700 text-white py-16">
        <div class="max-w-3xl mx-auto px-4">
          <div class="mb-6">
            <Breadcrumbs dark items={[
              { label: 'Inicio', href: '/' },
              { label: 'Blog', href: '/blog' },
              { label: post.title, href: `/blog/${post.slug}` },
            ]} />
          </div>
          <div class="flex items-center gap-3 mb-4">
            <span class={`px-3 py-1 text-sm font-medium rounded ${
              post.author_type === 'doctor' 
                ? 'bg-primary-600 text-white' 
                : 'bg-secondary-600 text-white'
            }`}>
              {post.author_type === 'doctor' ? 'Dr. Ipinza' : 'Automatizado'}
            </span>
            <span class="text-sm text-white/70">
              {new Date(post.published_at).toLocaleDateString('es-CL', {
                year: 'numeric',
                month: 'long',
                day: 'numeric'
              })}
            </span>
          </div>
          <h1 class="text-3xl md:text-4xl font-bold font-heading">{post.title}</h1>
          {post.excerpt && (
            <p class="mt-4 text-lg text-white/80">{post.excerpt}</p>
          )}
          <SchemaBreadcrumb items={[
            { name: 'Inicio', url: '/' },
            { name: 'Blog', url: '/blog' },
            { name: post.title, url: `/blog/${post.slug}` },
          ]} />
          <SchemaArticle
            headline={post.title}
            description={post.excerpt || `Artículo del blog del Dr. Ipinza`}
            datePublished={post.published_at}
            dateModified={post.updated_at || post.published_at}
            authorType={post.author_type === 'doctor' ? 'doctor' : 'clinic'}
          />
        </div>
      </header>

      <div class="max-w-3xl mx-auto px-4 py-12">
        <div class="bg-white rounded-lg shadow-sm p-8 md:p-12 prose-evolutiva" set:html={renderMarkdown(post.content_markdown)} />

        <RelatedServices topics={`${post.title} ${post.excerpt || ''}`} />

        <div class="mt-12 bg-secondary-50 rounded-lg p-8 text-center">
          <h3 class="text-2xl font-bold text-neutral-900 font-heading mb-4">¿Quieres un plan personalizado?</h3>
          <p class="text-neutral-600 mb-6">Completa nuestro cuestionario y recibe recomendaciones basadas en tu perfil.</p>
          <a href="/auth/registro/" class="inline-flex items-center gap-2 bg-primary-600 text-white font-semibold px-6 py-3 rounded-md hover:bg-primary-700 transition-colors no-underline">
            Crear Mi Plan Gratis <Icon name="lucide:arrow-right" class="w-5 h-5"  aria-hidden="true"/>
          </a>
        </div>
      </div>
    </article>
  )}
</BaseLayout>
