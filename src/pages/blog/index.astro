---
import Layout from '../../Layout.astro';
---

<Layout title="Blog | Centro de Salud Holística">
  <main class="min-h-screen bg-gray-50">
    <section class="bg-emerald-900 text-white py-16">
      <div class="max-w-4xl mx-auto px-4">
        <h1 class="text-4xl font-serif mb-4">Blog de Salud Evolutiva</h1>
        <p class="text-emerald-200 text-lg">Artículos del Dr. Ipinza y contenido sobre odontología holística y bienestar.</p>
      </div>
    </section>

    <section class="py-12">
      <div class="max-w-4xl mx-auto px-4">
        <div id="posts-grid" class="grid md:grid-cols-2 gap-8">
          <div class="col-span-2 text-center py-12">
            <div class="text-5xl mb-4">📝</div>
            <h3 class="text-xl font-serif text-gray-900 mb-2">Próximamente</h3>
            <p class="text-gray-600">Estamos preparando contenido nuevo para ti.</p>
          </div>
        </div>
      </div>
    </section>

    <section class="bg-emerald-50 py-12">
      <div class="max-w-4xl mx-auto px-4 text-center">
        <h3 class="text-2xl font-serif text-gray-900 mb-4">¿Listo para empezar tu camino?</h3>
        <p class="text-gray-600 mb-6">Crea tu cuenta gratuita y recibe un plan personalizado.</p>
        <a href="/auth/registro/" class="inline-flex items-center gap-2 bg-emerald-700 text-white px-6 py-3 rounded-lg font-medium hover:bg-emerald-800">Crear Cuenta Gratis</a>
      </div>
    </section>
  </main>

  <script>
    import PocketBase from 'pocketbase';
    const pb = new PocketBase('http://64.176.16.231:8090');

    async function loadPosts() {
      try {
        const records = await pb.collection('blog').getList(1, 10, { filter: 'status="published"', sort: '-published_at' });
        const grid = document.getElementById('posts-grid');
        if (!records.items.length || !grid) return;

        grid.innerHTML = records.items.map((post: any) => `
          <article class="bg-white rounded-xl shadow-md overflow-hidden hover:shadow-lg transition">
            <div class="p-6">
              <div class="flex items-center gap-2 mb-3">
                <span class="px-2 py-1 text-xs font-medium rounded ${post.author_type === 'doctor' ? 'bg-emerald-100 text-emerald-700' : 'bg-blue-100 text-blue-700'}">${post.author_type === 'doctor' ? 'Dr. Ipinza' : 'Automatizado'}</span>
                <span class="text-xs text-gray-500">${new Date(post.published_at).toLocaleDateString('es-CL')}</span>
              </div>
              <h2 class="text-xl font-serif text-gray-900 mb-2">${post.title}</h2>
              <p class="text-gray-600 text-sm mb-4 line-clamp-3">${post.excerpt || ''}</p>
              <a href="/blog/${post.slug}/" class="inline-flex items-center gap-2 text-emerald-700 font-medium hover:text-emerald-800">Leer más →</a>
            </div>
          </article>
        `).join('');
      } catch (err) { console.error(err); }
    }
    loadPosts();
  </script>
</Layout>
