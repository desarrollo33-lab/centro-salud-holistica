---
import BaseLayout from "../../layouts/BaseLayout.astro";
import HeroInner from "../../components/sections/HeroInner.astro";
import Section from "../../components/ui/Section.astro";
import Container from "../../components/ui/Container.astro";
import { getBlogPosts } from "../../lib/pocketbase";

let posts = [];
try {
  posts = await getBlogPosts();
} catch (e) {
  console.error('Error loading blog posts:', e);
}
---

<BaseLayout
  title="Blog de Salud Evolutiva | Centro de Salud Holística"
  description="Artículos del Dr. Ipinza sobre odontología holística, nutrición evolutiva, prevención y bienestar general. Contenido educativo gratuito."
>
  <HeroInner
    title="Blog de Salud Evolutiva"
    subtitle="Artículos del Dr. Ipinza y contenido automatizado sobre odontología holística, nutrición evolutiva y bienestar general."
    breadcrumbs={[
      { label: "Inicio", href: "/" },
      { label: "Blog", href: "/blog" },
    ]}
  />

  <Section>
    <Container>
      {posts.length > 0 ? (
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
          {posts.map((post) => (
            <a href={`/blog/${post.slug}/`} class="group block bg-white rounded-xl shadow-sm hover:shadow-lg hover:-translate-y-1 transition-all duration-200 overflow-hidden border border-neutral-200 hover:border-primary-300">
              <div class="p-6">
                <div class="flex items-center gap-2 mb-3">
                  <span class={`px-2 py-1 text-xs font-medium rounded ${
                    post.author_type === 'doctor' 
                      ? 'bg-primary-100 text-primary-700' 
                      : 'bg-secondary-100 text-secondary-700'
                  }`}>
                    {post.author_type === 'doctor' ? 'Dr. Ipinza' : 'Automatizado'}
                  </span>
                  <span class="text-xs text-neutral-500">
                    {new Date(post.published_at).toLocaleDateString('es-CL', {
                      year: 'numeric',
                      month: 'short',
                      day: 'numeric'
                    })}
                  </span>
                </div>
                <h3 class="text-lg font-semibold text-neutral-900 font-heading group-hover:text-primary-700 transition-colors mb-2">
                  {post.title}
                </h3>
                <p class="text-sm text-neutral-500 line-clamp-3 mb-4">
                  {post.excerpt || 'Sin descripción disponible'}
                </p>
                <span class="inline-flex items-center gap-1 text-primary-600 font-medium text-sm group-hover:gap-2 transition-all">
                  Leer más
                  <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"></path>
                  </svg>
                </span>
              </div>
            </a>
          ))}
        </div>
      ) : (
        <div class="text-center py-12">
          <div class="text-5xl mb-4">📝</div>
          <h3 class="text-xl font-semibold text-neutral-900 font-heading mb-2">Próximamente</h3>
          <p class="text-neutral-500">Estamos preparando contenido nuevo para ti.</p>
        </div>
      )}
    </Container>
  </Section>

  <Section bg="secondary">
    <Container>
      <div class="text-center max-w-2xl mx-auto">
        <h2 class="text-3xl font-bold text-neutral-900 font-heading mb-4">¿Listo para empezar tu camino?</h2>
        <p class="text-neutral-600 mb-8">
          Crea tu cuenta gratuita y recibe un plan de acción personalizado basado en el libro "Salud Evolutiva" del Dr. Ipinza.
        </p>
        <a href="/auth/registro/" class="inline-flex items-center gap-2 bg-primary-600 text-white font-semibold px-8 py-4 rounded-xl hover:bg-primary-700 transition-colors no-underline text-lg">
          Crear Cuenta Gratis →
        </a>
      </div>
    </Container>
  </Section>
</BaseLayout>
