---
import Layout from '../../Layout.astro';
---

<Layout title="Mi Cuenta | Centro de Salud Holística">
  <main class="min-h-screen bg-gray-50 py-12">
    <div class="max-w-4xl mx-auto px-4">
      <div class="flex justify-between items-center mb-8">
        <div>
          <h1 id="welcome-title" class="text-3xl font-serif text-gray-900 mb-2">Bienvenido</h1>
          <p class="text-gray-600">Tu progreso en el libro "Salud Evolutiva"</p>
        </div>
        <button id="logout-btn" class="text-gray-600 hover:text-gray-900 px-4 py-2 border border-gray-300 rounded-lg">Cerrar Sesión</button>
      </div>

      <div class="bg-white rounded-xl shadow-lg p-8 mb-8">
        <div class="flex items-center justify-between mb-6">
          <div>
            <h2 class="text-2xl font-serif text-gray-900">Tu Progreso</h2>
            <p id="progress-text" class="text-gray-600">0 de 7 capítulos completados</p>
          </div>
          <div class="text-right">
            <span id="progress-percent" class="text-4xl font-bold text-teal-700">0%</span>
          </div>
        </div>
        <div class="w-full bg-gray-200 rounded-full h-4">
          <div id="progress-bar" class="bg-teal-600 h-4 rounded-full transition-all" style="width: 0%"></div>
        </div>
      </div>

      <div class="grid md:grid-cols-3 gap-6 mb-8">
        <a href="/plan-accion/" class="bg-teal-700 text-white rounded-xl p-6 hover:bg-teal-800 transition">
          <div class="text-3xl mb-3">📋</div>
          <h3 class="font-semibold text-lg mb-2">Mi Plan de Acción</h3>
          <p class="text-teal-100 text-sm">Continuar con tu plan</p>
        </a>
        <a href="/libro/" class="bg-white text-gray-900 rounded-xl p-6 hover:shadow-lg transition border border-gray-200">
          <div class="text-3xl mb-3">📚</div>
          <h3 class="font-semibold text-lg mb-2">Continuar Leyendo</h3>
          <p class="text-gray-600 text-sm">Avanza en tu lectura</p>
        </a>
        <a href="/recursos/" class="bg-white text-gray-900 rounded-xl p-6 hover:shadow-lg transition border border-gray-200">
          <div class="text-3xl mb-3">✅</div>
          <h3 class="font-semibold text-lg mb-2">Herramientas</h3>
          <p class="text-gray-600 text-sm">Checklists y guías</p>
        </a>
      </div>

      <div class="bg-white rounded-xl shadow-lg p-8">
        <h2 class="text-2xl font-serif text-gray-900 mb-6">Progreso por Capítulo</h2>
        <div id="chapters-list" class="space-y-4"></div>
      </div>
    </div>
  </main>

  <script>
    import PocketBase from 'pocketbase';
    const pb = new PocketBase('http://64.176.16.231:8090');
    if (!pb.authStore.isValid) { window.location.href = '/auth/login/?redirect=/mi-cuenta/'; }

    const chapters = [
      { slug: 'palabras-del-autor', title: 'Palabras del Autor', num: 1, words: 922 },
      { slug: 'evolucion-cultural-vs-natural', title: 'Evolución Cultural vs Natural', num: 2, words: 4901 },
      { slug: 'enfermedades-orales-como-enfermedades-de-civilizacion', title: 'Enfermedades Orales', num: 3, words: 3983 },
      { slug: 'el-tripode-de-la-salud', title: 'El Trípode de la Salud', num: 4, words: 5842 },
      { slug: 'que-hacer-tratamientos', title: 'Qué Hacer — Tratamientos', num: 5, words: 5412 },
      { slug: 'anexos-enfoque-holistico-por-edades', title: 'Anexos', num: 6, words: 5412 },
    ];

    async function loadProgress() {
      const user = pb.authStore.model;
      if (user?.name) { document.getElementById('welcome-title')!.textContent = `Bienvenido, ${user.name}`; }
      try {
        const progressRecords = await pb.collection('user_progress').getFullList();
        const progressMap = new Map(progressRecords.map((p: any) => [p.chapter_slug, p]));
        const completedCount = progressRecords.filter((p: any) => p.completed).length;
        const percent = Math.round((completedCount / chapters.length) * 100);
        document.getElementById('progress-text')!.textContent = `${completedCount} de ${chapters.length} capítulos`;
        document.getElementById('progress-percent')!.textContent = `${percent}%`;
        document.getElementById('progress-bar')!.style.width = `${percent}%`;

        const list = document.getElementById('chapters-list')!;
        list.innerHTML = chapters.map(ch => {
          const prog = progressMap.get(ch.slug);
          const done = prog?.completed;
          return `<div class="flex items-center justify-between p-4 rounded-lg border border-gray-200 hover:border-teal-300">
            <div class="flex items-center gap-4">
              <div class="w-8 h-8 rounded-full flex items-center justify-center ${done ? 'bg-teal-600 text-white' : 'bg-gray-200 text-gray-600'}">${done ? '✓' : ch.num}</div>
              <div><h3 class="font-medium text-gray-900">${ch.title}</h3><p class="text-sm text-gray-500">${ch.words} palabras</p></div>
            </div>
            <a href="/libro/${ch.slug}/" class="px-4 py-2 bg-teal-50 text-teal-700 rounded-lg hover:bg-teal-100 text-sm">${done ? 'Revisar' : 'Leer'}</a>
          </div>`;
        }).join('');
      } catch (err) { console.error(err); }
    }

    document.getElementById('logout-btn')?.addEventListener('click', () => { pb.authStore.clear(); window.location.href = '/'; });
    loadProgress();
  </script>
</Layout>
