---
import { Icon } from "astro-icon/components";
import BaseLayout from "../../layouts/BaseLayout.astro";
import HeroInner from "../../components/sections/HeroInner.astro";
import Section from "../../components/ui/Section.astro";
import Container from "../../components/ui/Container.astro";
---

<BaseLayout title="Mi Cuenta | Centro de Salud Holística" description="Tu cuenta y progreso en el Centro de Salud Holística.">
  <HeroInner
    title="Mi Cuenta"
    subtitle="Tu progreso en el libro 'Salud Evolutiva' y plan de acción personalizado."
    breadcrumbs={[
      { label: "Inicio", href: "/" },
      { label: "Mi Cuenta", href: "/mi-cuenta" },
    ]}
  />

  <Section>
    <Container>
      <div class="grid md:grid-cols-3 gap-6 mb-8">
        <a href="/plan-accion/" class="group bg-primary-600 text-white rounded-lg p-6 hover:bg-primary-700 transition-colors">
          <div class="w-12 h-12 bg-white/20 rounded-lg flex items-center justify-center mb-3">
            <Icon name="lucide:clipboard-list" class="w-6 h-6 text-white"  aria-hidden="true"/>
          </div>
          <h3 class="font-semibold text-lg mb-2">Mi Plan de Acción</h3>
          <p class="text-primary-100 text-sm">Continuar con tu plan personalizado</p>
        </a>
        <a href="/libro/" class="group bg-white rounded-lg p-6 shadow-sm hover:shadow-md transition-all duration-200">
          <div class="w-12 h-12 bg-primary-50 rounded-lg flex items-center justify-center mb-3">
            <Icon name="lucide:book-open" class="w-6 h-6 text-primary-600"  aria-hidden="true"/>
          </div>
          <h3 class="font-semibold text-lg text-neutral-900 mb-2">Continuar Leyendo</h3>
          <p class="text-neutral-500 text-sm">Avanza en tu lectura del libro</p>
        </a>
        <a href="/recursos/" class="group bg-white rounded-lg p-6 shadow-sm hover:shadow-md transition-all duration-200">
          <div class="w-12 h-12 bg-primary-50 rounded-lg flex items-center justify-center mb-3">
            <Icon name="lucide:circle-check" class="w-6 h-6 text-primary-600"  aria-hidden="true"/>
          </div>
          <h3 class="font-semibold text-lg text-neutral-900 mb-2">Herramientas</h3>
          <p class="text-neutral-500 text-sm">Checklists y guías prácticas</p>
        </a>
      </div>

      <div class="bg-white rounded-lg shadow-sm p-8 mb-8">
        <div class="flex items-center justify-between mb-6">
          <div>
            <h2 id="welcome-title" class="text-2xl font-bold text-neutral-900 font-heading">Tu Progreso</h2>
            <p id="progress-text" class="text-neutral-600">Cargando...</p>
          </div>
          <div class="text-right">
            <span id="progress-percent" class="text-4xl font-bold text-primary-600">0%</span>
          </div>
        </div>
        <div class="w-full bg-neutral-100 rounded-full h-4 mb-6">
          <div id="progress-bar" class="bg-primary-600 h-4 rounded-full transition-all" style="width: 0%"></div>
        </div>
        <div id="chapters-list" class="space-y-3"></div>
      </div>

      <div class="text-center">
        <button id="logout-btn" class="inline-flex items-center gap-2 px-6 py-3 border border-neutral-300 text-neutral-700 rounded-lg hover:bg-neutral-50 transition-colors">
          <Icon name="lucide:log-out" class="w-5 h-5"  aria-hidden="true"/>
          Cerrar Sesión
        </button>
      </div>
    </Container>
  </Section>

  <script>
    const chapters = [
      { slug: 'palabras-del-autor', title: 'Palabras del Autor', num: 0, words: 922 },
      { slug: 'capitulo-1', title: 'Evolución Cultural vs Natural', num: 1, words: 4901 },
      { slug: 'capitulo-2', title: 'Enfermedades Orales como Enfermedad de Civilización', num: 2, words: 3983 },
      { slug: 'capitulo-3', title: 'Qué Hacer — El Trípode de la Salud', num: 3, words: 5842 },
      { slug: 'capitulo-4', title: 'Odontología', num: 4, words: 8347 },
      { slug: 'capitulo-5', title: 'Anexos', num: 5, words: 5412 },
      { slug: 'epilogo', title: 'Epílogo', num: 6, words: 244 },
    ];

    function getAuth() {
      try {
        const stored = localStorage.getItem('pb_auth');
        return stored ? JSON.parse(stored) : null;
      } catch { return null; }
    }

    function isAuthValid(auth) {
      if (!auth?.token) return false;
      try {
        const payload = JSON.parse(atob(auth.token.split('.')[1]));
        return payload.exp * 1000 > Date.now();
      } catch { return false; }
    }

    const auth = getAuth();
    if (!auth || !isAuthValid(auth)) {
      window.location.href = '/auth/login/?redirect=/mi-cuenta/';
    }

    async function checkAuthAndLoadProgress() {
      const auth = getAuth();
      if (!auth) return;
      
      const user = auth.model;
      if (user?.name) {
        document.getElementById('welcome-title')!.textContent = `Bienvenido, ${user.name}`;
      }
      
      try {
        const response = await fetch('/api/progress', {
          headers: { 'Authorization': auth.token }
        });
        
        if (!response.ok) {
          throw new Error('No se pudo cargar el progreso');
        }
        
        const data = await response.json();
        const progressRecords = data.items || [];
        
        displayProgress(progressRecords);
      } catch (err) {
        console.error(err);
        document.getElementById('progress-text')!.textContent = 'No se pudo cargar el progreso';
      }
    }

    function displayProgress(progressRecords) {
      const progressMap = new Map(progressRecords.map((p) => [p.chapter_slug, p]));
      const completedCount = progressRecords.filter((p) => p.completed).length;
      const percent = Math.round((completedCount / chapters.length) * 100);
      
      document.getElementById('progress-text')!.textContent = `${completedCount} de ${chapters.length} capítulos completados`;
      document.getElementById('progress-percent')!.textContent = `${percent}%`;
      document.getElementById('progress-bar')!.style.width = `${percent}%`;

      const list = document.getElementById('chapters-list')!;
      list.innerHTML = chapters.map(ch => {
        const prog = progressMap.get(ch.slug);
        const done = prog?.completed;
        return `<div class="flex items-center justify-between p-4 rounded-lg border border-neutral-200 hover:border-primary-300 transition-colors">
          <div class="flex items-center gap-4">
            <div class="w-8 h-8 rounded-full flex items-center justify-center ${done ? 'bg-primary-600 text-white' : 'bg-neutral-100 text-neutral-600'}">${done ? '<svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M5 13l4 4L19 7"/></svg>' : ch.num}</div>
            <div>
              <h3 class="font-medium text-neutral-900">${ch.title}</h3>
              <p class="text-sm text-neutral-500">${ch.words.toLocaleString()} palabras</p>
            </div>
          </div>
          <a href="/libro/${ch.slug}/" class="px-4 py-2 bg-primary-50 text-primary-700 rounded-lg hover:bg-primary-100 text-sm font-medium transition-colors">${done ? 'Revisar' : 'Leer'}</a>
        </div>`;
      }).join('');
    }

    document.getElementById('logout-btn')?.addEventListener("click", () => {
      localStorage.removeItem('pb_auth');
      window.location.href = '/';
    });

    checkAuthAndLoadProgress();
  </script>
</BaseLayout>
