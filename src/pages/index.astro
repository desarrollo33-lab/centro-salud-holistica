---
import { Icon } from "astro-icon/components";
import BaseLayout from "../layouts/BaseLayout.astro";
import HeroHome from "../components/sections/HeroHome.astro";
import Section from "../components/ui/Section.astro";
import Container from "../components/ui/Container.astro";
import ServiceGrid from "../components/sections/ServiceGrid.astro";
import Testimonials from "../components/sections/Testimonials.astro";
import CTASection from "../components/sections/CTASection.astro";
import Badge from "../components/ui/Badge.astro";
import { services, siteConfig } from "../data/site";

const featuredServices = services.slice(0, 6);

const testimonials = [
  { quote: "Nunca había ido al dentista sin sentir miedo. El Dr. Ipinza me explicó todo con una paciencia increíble. La eliminación de amalgamas fue mucho más tranquila de lo que esperaba.", author: "María José R.", location: "Las Condes, Santiago" },
  { quote: "Después de años con problemas de ATM, por fin encontré un enfoque integral. No solo me trataron la mandíbula, sino que entendieron que mi problema venía de más abajo.", author: "Andrés L.", location: "Providencia, Santiago" },
  { quote: "Les implants céramiques ont été la meilleure décision. Aucune sensibilité, et le résultat est parfaitement naturel. Je recommande à 100%.", author: "Catherine D.", location: "Francia (paciente internacional)" },
];
---

<BaseLayout
  title="Centro de Salud Holística Dr. Ipinza | Odontología Biológica en Santiago"
  description="Centro de odontología holística y biológica en Santiago. Eliminación de amalgamas con Protocolo IAOMT, implantes cerámicos sin titanio, odontología biomimética y más. Los Dominicos, Las Condes."
>
  <HeroHome />

  <!-- Filosofía y Diferenciación -->
  <Section bg="secondary" id="filosofia">
    <Container>
      <!-- Header: texto + logo en 2 columnas -->
      <div class="grid lg:grid-cols-2 gap-8 lg:gap-12 items-center mb-8">
        <div data-animate="fade-left">
          <Badge variant="secondary" class="inline-flex items-center gap-1.5 mb-6">
            <Icon name="lucide:sparkles" class="w-4 h-4" /> Nuestra filosofía
          </Badge>
          <h2 class="font-heading font-bold text-3xl md:text-4xl text-neutral-900 mb-4">
            Odontología de última generación que respeta tu biología
          </h2>
          <p class="text-lg text-neutral-600 leading-relaxed mb-4">
            Mientras la odontología tradicional reacciona al problema, nosotros buscamos la causa. <strong class="text-neutral-800">Tecnología de punta</strong> — implantes de circonio, planificación 3D, ozonoterapia — al servicio de un enfoque que trata a la persona completa, no solo al diente.
          </p>
          <blockquote class="border-l-4 border-secondary-300 bg-white/60 pl-4 py-1">
            <p class="text-sm text-neutral-500 italic leading-relaxed">
              "La odontología del futuro no es la que inventa más máquinas, sino la que escucha más profundamente la biología y la sabiduría ancestral."
            </p>
            <cite class="block mt-1 text-xs text-neutral-400 not-italic font-medium">— Dr. Joaquín Ipinza, <em>Salud Evolutiva</em></cite>
          </blockquote>
        </div>
        <div data-animate="fade-right" class="flex justify-center">
          <img
            src="/images/logo_horizontal_saludEvolutiva.webp"
            alt="Salud Evolutiva — Odontología Holística Dr. Ipinza"
            width="340"
            height="340"
            class="w-full max-w-[340px] aspect-square object-cover rounded-xl"
            loading="eager"
          />
        </div>
      </div>

      <!-- 4 Pilares en filas horizontales compactas -->
      <div data-stagger class="grid grid-cols-1 md:grid-cols-2 gap-4 mb-8">
        <!-- Pilar 1 -->
        <article class="flex gap-4 p-4 bg-white rounded-xl border border-neutral-200 hover:shadow-md transition-shadow duration-200">
          <div class="w-10 h-10 bg-secondary-50 border border-neutral-200 rounded-lg flex items-center justify-center shrink-0">
            <Icon name="lucide:scan" class="w-5 h-5 text-secondary-600" />
          </div>
          <div>
            <h3 class="font-heading font-semibold text-neutral-900 mb-1">Diagnóstico 3D y Planificación Digital</h3>
            <p class="text-sm text-neutral-500 leading-relaxed">Tomografía cone beam y cirugía guiada por computadora. <strong class="text-neutral-700">Precisión milimétrica</strong> en cada procedimiento, como lo hacen las clínicas más avanzadas del mundo.</p>
          </div>
        </article>

        <!-- Pilar 2 -->
        <article class="flex gap-4 p-4 bg-white rounded-xl border border-neutral-200 hover:shadow-md transition-shadow duration-200">
          <div class="w-10 h-10 bg-primary-50 border border-neutral-200 rounded-lg flex items-center justify-center shrink-0">
            <Icon name="lucide:shield-check" class="w-5 h-5 text-primary-600" />
          </div>
          <div>
            <h3 class="font-heading font-semibold text-neutral-900 mb-1">Cero Metales Pesados en Tu Cuerpo</h3>
            <p class="text-sm text-neutral-500 leading-relaxed">Protocolo <strong class="text-neutral-700">IAOMT</strong> para remoción segura de amalgamas. Implantes de circonio — no titanio — con osteointegración comprobada.</p>
          </div>
        </article>

        <!-- Pilar 3 -->
        <article class="flex gap-4 p-4 bg-white rounded-xl border border-neutral-200 hover:shadow-md transition-shadow duration-200">
          <div class="w-10 h-10 bg-primary-50 border border-neutral-200 rounded-lg flex items-center justify-center shrink-0">
            <Icon name="lucide:sparkles" class="w-5 h-5 text-primary-600" />
          </div>
          <div>
            <h3 class="font-heading font-semibold text-neutral-900 mb-1">Odontología Biomimética</h3>
            <p class="text-sm text-neutral-500 leading-relaxed">Conservamos tu diente natural al máximo. Restauraciones de <strong class="text-neutral-700">cerámica adherida</strong> que sellan, fortalecen e imitan la estructura original — sin cortar de más.</p>
          </div>
        </article>

        <!-- Pilar 4 -->
        <article class="flex gap-4 p-4 bg-white rounded-xl border border-neutral-200 hover:shadow-md transition-shadow duration-200">
          <div class="w-10 h-10 bg-secondary-50 border border-neutral-200 rounded-lg flex items-center justify-center shrink-0">
            <Icon name="lucide:heart-pulse" class="w-5 h-5 text-secondary-600" />
          </div>
          <div>
            <h3 class="font-heading font-semibold text-neutral-900 mb-1">Salud Integral, No Solo Dental</h3>
            <p class="text-sm text-neutral-500 leading-relaxed">Ozonoterapia, acupuntura y nutrición funcional integradas al tratamiento. Porque tu <strong class="text-neutral-700">boca está conectada con todo tu cuerpo</strong>.</p>
          </div>
        </article>
      </div>

      <!-- CTA -->
      <div data-animate="fade-up" class="text-center">
        <a href="/sobre" class="inline-flex items-center gap-2 bg-primary-600 text-white font-semibold px-6 py-3 rounded-lg hover:bg-primary-700 hover:shadow-md hover:-translate-y-px transition-all duration-150 no-underline">
          Conoce nuestra filosofía <Icon name="lucide:arrow-right" class="w-4 h-4" />
        </a>
      </div>
    </Container>
  </Section>

  <!-- Services -->
  <Section>
    <Container>
      <div data-animate="fade-up" class="text-center mb-12">
        <Badge variant="primary" class="inline-flex items-center gap-1.5 mb-6">
          <Icon name="lucide:stethoscope" class="w-4 h-4" /> Nuestros Servicios
        </Badge>
        <h2 class="font-heading font-bold text-3xl text-neutral-900 mb-4">Tratamientos biocompatibles diseñados para tu salud integral</h2>
        <p class="text-neutral-500 max-w-2xl mx-auto">Odontología de última generación: eliminación de amalgamas, implantes cerámicos sin titanio, biomimesis y terapias integradas.</p>
      </div>
      <div data-stagger>
        <ServiceGrid services={featuredServices} />
      </div>
      <div data-animate="fade-up" class="text-center mt-10">
        <a href="/servicios" class="inline-flex items-center gap-2 border-2 border-primary-600 text-primary-600 font-semibold px-6 py-3 rounded-lg hover:bg-primary-600 hover:text-white hover:shadow-md hover:-translate-y-px transition-all duration-150 no-underline">
          Ver todos los servicios ({services.length})
          <Icon name="lucide:arrow-right" class="w-4 h-4" />
        </a>
      </div>
    </Container>
  </Section>

  <!-- About Doctor Teaser -->
  <Section bg="white">
    <Container>
      <div class="grid lg:grid-cols-2 gap-8 lg:gap-12 items-center">
        <div data-animate="fade-left">
          <Badge variant="secondary" class="inline-flex items-center gap-1.5 mb-6">
            <Icon name="lucide:user-round" class="w-4 h-4" /> El Doctor
          </Badge>
          <h2 class="font-heading font-bold text-3xl text-neutral-900 mb-4">
            {siteConfig.doctor}
          </h2>
          <p class="text-neutral-600 leading-relaxed mb-6">
            Cirujano dentista de la Universidad de Chile, con especialización en Periodoncia e Implantología. Formación adicional en Loma Linda University, California. Su enfoque holístico integra nutrición, acupuntura y ozonoterapia con la odontología.
          </p>
          <div class="flex flex-wrap gap-2 mb-8">
            {siteConfig.certifications.slice(0,3).map((cert) => (
              <Badge variant="neutral">{cert}</Badge>
            ))}
          </div>
          <a href="/sobre" class="inline-flex items-center gap-2 border-2 border-primary-600 text-primary-600 font-semibold px-6 py-3 rounded-lg hover:bg-primary-600 hover:text-white hover:shadow-md hover:-translate-y-px transition-all duration-150 no-underline">
            Conoce más sobre el doctor <Icon name="lucide:arrow-right" class="w-4 h-4" />
          </a>
        </div>
        <div data-animate="fade-right" class="flex justify-center lg:justify-end">
          <img
            src="/images/doctor-retrato.webp"
            alt="Dr. Joaquín Ipinza — Cirujano dentista y autor de Salud Evolutiva"
            width="340"
            height="340"
            class="w-full max-w-[340px] aspect-square object-cover rounded-xl"
            loading="eager"
          />
        </div>
      </div>
    </Container>
  </Section>

  <!-- Book Section -->
  <Section bg="secondary">
    <Container>
      <div class="grid lg:grid-cols-2 gap-8 lg:gap-12 items-center">
        <div data-animate="fade-right" class="flex justify-center lg:justify-start order-1 lg:order-none">
          <img
            src="/images/portada_libro-light.webp"
            alt="Portada del libro {siteConfig.bookTitle} — {siteConfig.doctor}"
            width="340"
            height="340"
            class="w-full max-w-[340px] aspect-square object-cover rounded-xl"
            loading="eager"
          />
        </div>
        <div data-animate="fade-left">
          <Badge variant="primary" class="inline-flex items-center gap-1.5 mb-6">
            <Icon name="lucide:book-open" class="w-4 h-4" /> Libro Gratuito
          </Badge>
          <h2 class="font-heading font-bold text-3xl text-neutral-900 mb-4">
            {siteConfig.bookTitle}
          </h2>
          <p class="text-neutral-600 leading-relaxed mb-6">
            {siteConfig.bookDescription} Escrito para que cualquier persona lo entienda — sin ser odontólogo.
          </p>
          <ul class="space-y-2.5 mb-8">
            <li class="flex items-center gap-2.5 text-sm text-neutral-600">
              <Icon name="lucide:check" class="w-4 h-4 text-success shrink-0" />
              129 páginas basadas en evidencia científica verificable
            </li>
            <li class="flex items-center gap-2.5 text-sm text-neutral-600">
              <Icon name="lucide:check" class="w-4 h-4 text-success shrink-0" />
              Evolución, nutrición ancestral y salud bucal explicadas con claridad
            </li>
            <li class="flex items-center gap-2.5 text-sm text-neutral-600">
              <Icon name="lucide:check" class="w-4 h-4 text-success shrink-0" />
              Completo, sin registro y sin costo
            </li>
          </ul>
          <a href="/libro" class="inline-flex items-center gap-2 bg-primary-600 text-white font-semibold px-6 py-3 rounded-lg hover:bg-primary-700 hover:shadow-md hover:-translate-y-px transition-all duration-150 no-underline">
            Leer el libro completo <Icon name="lucide:arrow-right" class="w-4 h-4" />
          </a>
        </div>
      </div>
    </Container>
  </Section>

  <!-- Testimonials -->
  <Section bg="white">
    <Container>
      <div data-animate="fade-up">
        <Testimonials testimonials={testimonials} />
      </div>
    </Container>
  </Section>

  <!-- Stats -->
  <Section bg="primary">
    <Container>
      <div data-stagger class="grid grid-cols-2 lg:grid-cols-4 gap-8 text-center">
        <div>
          <p class="text-4xl font-bold text-white font-heading">{siteConfig.stats.yearsOfExperience}+</p>
          <p class="mt-1 text-white/70 text-sm">Años de experiencia</p>
        </div>
        <div>
          <p class="text-4xl font-bold text-white font-heading">{siteConfig.stats.patientsTreated}</p>
          <p class="mt-1 text-white/70 text-sm">Pacientes atendidos</p>
        </div>
        <div>
          <p class="text-4xl font-bold text-white font-heading">{siteConfig.stats.treatmentsCompleted}+</p>
          <p class="mt-1 text-white/70 text-sm">Tratamientos completados</p>
        </div>
        <div>
          <p class="text-4xl font-bold text-white font-heading">{siteConfig.stats.certifications}</p>
          <p class="mt-1 text-white/70 text-sm">Certificaciones</p>
        </div>
      </div>
    </Container>
  </Section>

  <CTASection />
</BaseLayout>
