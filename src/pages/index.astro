---
import { Icon } from "astro-icon/components";
import BaseLayout from "../layouts/BaseLayout.astro";
import HeroHome from "../components/sections/HeroHome.astro";
import Section from "../components/ui/Section.astro";
import Container from "../components/ui/Container.astro";
import ServiceGrid from "../components/sections/ServiceGrid.astro";
import Testimonials from "../components/sections/Testimonials.astro";
import CTASection from "../components/sections/CTASection.astro";
import Badge from "../components/ui/Badge.astro";
import { services, siteConfig } from "../data/site";

const featuredServices = services.slice(0, 6);

const testimonials = [
  { quote: "Nunca había ido al dentista sin sentir miedo. El Dr. Ipinza me explicó todo con una paciencia increíble. La eliminación de amalgamas fue mucho más tranquila de lo que esperaba.", author: "María José R.", location: "Las Condes, Santiago" },
  { quote: "Después de años con problemas de ATM, por fin encontré un enfoque integral. No solo me trataron la mandíbula, sino que entendieron que mi problema venía de más abajo.", author: "Andrés L.", location: "Providencia, Santiago" },
  { quote: "Les implants céramiques ont été la meilleure décision. Aucune sensibilité, et le résultat est parfaitement naturel. Je recommande à 100%.", author: "Catherine D.", location: "Francia (paciente internacional)" },
];
---

<BaseLayout
  title="Centro de Salud Holística Dr. Ipinza | Odontología Biológica en Santiago"
  description="Centro de odontología holística y biológica en Santiago. Eliminación de amalgamas con Protocolo IAOMT, implantes cerámicos sin titanio, odontología biomimética y más. Los Dominicos, Las Condes."
>
  <HeroHome />

  <!-- Filosofía y Diferenciación -->
  <Section bg="secondary" id="filosofia">
    <Container>
      <div data-animate="fade-up" class="max-w-3xl mx-auto text-center mb-12">
        <Badge variant="secondary" class="inline-flex items-center gap-1.5 mb-6">
          <Icon name="lucide:sparkles" class="w-4 h-4" /> Nuestra filosofía
        </Badge>
        <h2 class="font-heading font-bold text-3xl md:text-4xl text-neutral-900 mb-4">
          ¿Por qué enferman nuestros dientes si la evolución nos diseñó sanos?
        </h2>
        <p class="text-lg text-neutral-600 leading-relaxed">
          Las enfermedades bucales son <strong class="text-neutral-800">enfermedades de la civilización</strong>. Nuestra odontología vuelve a sincronizar tu boca con la lógica de la vida.
        </p>
      </div>

      <!-- Logo como sello -->
      <div data-animate="fade-up" class="flex justify-center mb-12">
        <img
          src="/images/logo_horizontal_saludEvolutiva.png"
          alt="Salud Evolutiva — Odontología Holística Dr. Ipinza"
          width="320"
          height="auto"
          class="h-12 md:h-14 w-auto opacity-90"
          loading="eager"
        />
      </div>

      <!-- 4 Pilares -->
      <div data-stagger class="grid grid-cols-1 md:grid-cols-2 gap-6 max-w-4xl mx-auto">
        <!-- Pilar 1 -->
        <div class="bg-white rounded-xl p-6 border border-secondary-200 hover:shadow-md transition-shadow duration-200">
          <div class="w-11 h-11 rounded-lg bg-secondary-50 border border-secondary-200 flex items-center justify-center mb-4">
            <Icon name="lucide:layers" class="w-5 h-5 text-secondary-600" />
          </div>
          <h3 class="font-heading font-semibold text-neutral-900 mb-2">Nivel 3 Terapéutico</h3>
          <p class="text-sm text-neutral-600 leading-relaxed">
            La odontología tradicional se queda en el diente (Nivel&nbsp;1). Nosotros conectamos <strong>boca‑cuerpo</strong> (Nivel&nbsp;2) y <strong>persona‑entorno</strong> (Nivel&nbsp;3). Tu salud bucal es parte de tu salud integral.
          </p>
        </div>

        <!-- Pilar 2 -->
        <div class="bg-white rounded-xl p-6 border border-secondary-200 hover:shadow-md transition-shadow duration-200">
          <div class="w-11 h-11 rounded-lg bg-primary-50 border border-primary-200 flex items-center justify-center mb-4">
            <Icon name="lucide:shield-check" class="w-5 h-5 text-primary-600" />
          </div>
          <h3 class="font-heading font-semibold text-neutral-900 mb-2">Cero Metales Pesados</h3>
          <p class="text-sm text-neutral-600 leading-relaxed">
            Protocolo <strong>IAOMT</strong> certificado para la remoción segura de amalgamas. Usamos solo materiales biocompatibles — cerámica, circonio, composite. Tu sistema inmune agradece.
          </p>
        </div>

        <!-- Pilar 3 -->
        <div class="bg-white rounded-xl p-6 border border-secondary-200 hover:shadow-md transition-shadow duration-200">
          <div class="w-11 h-11 rounded-lg bg-primary-50 border border-primary-200 flex items-center justify-center mb-4">
            <Icon name="lucide:leaf" class="w-5 h-5 text-primary-600" />
          </div>
          <h3 class="font-heading font-semibold text-neutral-900 mb-2">Ciencia + Naturaleza</h3>
          <p class="text-sm text-neutral-600 leading-relaxed">
            Combinamos evidencia científica con nutrición ancestral. No tratamos solo síntomas — abordamos la <strong>raíz evolutiva</strong> de las enfermedades bucales, como demostró Weston Price.
          </p>
        </div>

        <!-- Pilar 4 -->
        <div class="bg-white rounded-xl p-6 border border-secondary-200 hover:shadow-md transition-shadow duration-200">
          <div class="w-11 h-11 rounded-lg bg-secondary-50 border border-secondary-200 flex items-center justify-center mb-4">
            <Icon name="lucide:heart-handshake" class="w-5 h-5 text-secondary-600" />
          </div>
          <h3 class="font-heading font-semibold text-neutral-900 mb-2">Persona, No Diente</h3>
          <p class="text-sm text-neutral-600 leading-relaxed">
            Acupuntura, nutrición, ozonoterapia y terapia neural integradas al tratamiento dental. Porque <strong>detrás de cada sonrisa hay una historia</strong>, emociones y un entorno que cuidar.
          </p>
        </div>
      </div>

      <!-- Cita del epílogo -->
      <div data-animate="fade-up" class="mt-12 text-center">
        <blockquote class="max-w-2xl mx-auto">
          <p class="text-neutral-600 italic leading-relaxed text-sm md:text-base">
            "La odontología del futuro no es la que inventa más máquinas, sino la que escucha más profundamente la biología y la sabiduría ancestral."
          </p>
          <cite class="block mt-3 text-xs text-neutral-400 not-italic font-medium">— Dr. Joaquín Ipinza, <em>Salud Evolutiva</em></cite>
        </blockquote>
      </div>
    </Container>
  </Section>

  <!-- Services -->
  <Section>
    <Container>
      <div data-animate="fade-up">
        <div class="text-center mb-12">
          <h2 class="text-3xl font-bold text-neutral-900 font-heading">Nuestros Servicios</h2>
          <p class="mt-4 text-lg text-neutral-500 max-w-2xl mx-auto">Tratamientos biocompatibles diseñados para tu salud integral</p>
        </div>
      </div>
      <div data-stagger>
        <ServiceGrid services={featuredServices} />
      </div>
      <div data-animate="fade-up" class="text-center mt-12">
        <a href="/servicios" class="inline-flex items-center gap-2 text-accent font-semibold no-underline group">
          Ver todos los servicios ({services.length})
          <Icon name="lucide:arrow-right" class="w-5 h-5 group-hover:translate-x-1 transition-transform duration-200" />
        </a>
      </div>
    </Container>
  </Section>

  <!-- About Doctor Teaser -->
  <Section bg="white">
    <Container>
      <div class="grid md:grid-cols-2 gap-12 items-center">
        <div data-animate="fade-left">
          <Badge variant="secondary" class="inline-flex items-center gap-1.5">
            <Icon name="lucide:user-round" class="w-4 h-4" /> El Doctor
          </Badge>
          <h2 class="font-heading font-bold text-3xl text-neutral-900 mt-4 mb-4">
            {siteConfig.doctor}
          </h2>
          <p class="text-neutral-700 leading-relaxed mb-6">
            Cirujano dentista de la Universidad de Chile, con especialización en Periodoncia e Implantología. Formación adicional en Loma Linda University, California. Su enfoque holístico integra nutrición, acupuntura y ozonoterapia con la odontología.
          </p>
          <div class="flex flex-wrap gap-2 mb-8">
            {siteConfig.certifications.slice(0,3).map((cert) => (
              <Badge variant="neutral">{cert}</Badge>
            ))}
          </div>
          <a href="/sobre" class="inline-flex items-center gap-2 text-accent font-semibold no-underline group">
            Conoce más sobre el doctor <Icon name="lucide:arrow-right" class="w-4 h-4 group-hover:translate-x-1 transition-transform duration-200" />
          </a>
        </div>
        <div data-animate="fade-right">
          <div class="bg-gradient-to-br from-primary-100 to-secondary-50 rounded-lg aspect-square flex items-center justify-center">
            <div class="text-center">
              <div class="w-32 h-32 bg-primary-200 rounded-full mx-auto mb-4 flex items-center justify-center">
                <Icon name="lucide:user-round" class="w-16 h-16 text-primary-400" />
              </div>
              <p class="text-primary-700 text-sm font-medium">Foto profesional<br />por confirmar</p>
            </div>
          </div>
        </div>
      </div>
    </Container>
  </Section>

  <!-- Book Section -->
  <Section bg="secondary">
    <Container>
      <div class="grid md:grid-cols-2 gap-12 items-center">
        <div data-animate="fade-left">
          <Badge variant="secondary" class="inline-flex items-center gap-1.5">
            <Icon name="lucide:book-open" class="w-4 h-4" /> Contenido educativo gratuito
          </Badge>
          <h2 class="font-heading font-bold text-3xl text-neutral-900 mt-4 mb-4">
            {siteConfig.bookTitle}: el libro que cambia perspectiva
          </h2>
          <p class="text-neutral-700 leading-relaxed mb-6">
            {siteConfig.bookDescription} Escrito para que cualquier persona lo entienda, sin ser odontólogo.
          </p>
          <ul class="space-y-2 mb-8">
            <li class="flex items-center gap-2 text-sm text-neutral-600">
              <Icon name="lucide:check" class="w-4 h-4 text-success shrink-0" />
              Gratuito para leer online, completo y sin registro
            </li>
            <li class="flex items-center gap-2 text-sm text-neutral-600">
              <Icon name="lucide:check" class="w-4 h-4 text-success shrink-0" />
              5 capítulos sobre evolución, nutrición y salud bucal
            </li>
            <li class="flex items-center gap-2 text-sm text-neutral-600">
              <Icon name="lucide:check" class="w-4 h-4 text-success shrink-0" />
              Referencias científicas verificables
            </li>
          </ul>
          <a href="/libro" class="inline-flex items-center gap-2 bg-primary-600 text-white font-semibold px-6 py-3 rounded-lg hover:bg-primary-700 hover:shadow-md hover:-translate-y-px transition-all duration-150 no-underline">
            <Icon name="lucide:book-open" class="w-5 h-5" /> Leer el libro completo <Icon name="lucide:arrow-right" class="w-4 h-4" />
          </a>
        </div>
        <div data-animate="fade-right">
          <div class="bg-white rounded-lg shadow-sm p-8">
            <div class="text-center">
              <img
                src="/images/portada-libro.webp"
                alt="Portada del libro {siteConfig.bookTitle} — {siteConfig.doctor}"
                width="800"
                height="874"
                class="w-52 h-auto mx-auto mb-6 rounded-lg shadow-md"
                loading="eager"
                decoding="async"
              />
              <h3 class="font-heading font-bold text-lg text-neutral-900">{siteConfig.bookTitle}</h3>
              <p class="text-sm text-neutral-500 mb-1">{siteConfig.doctor}</p>
              <p class="text-xs text-neutral-400">129 páginas · 38,000 palabras · Gratuito</p>
            </div>
          </div>
        </div>
      </div>
    </Container>
  </Section>

  <!-- Testimonials -->
  <Section bg="white">
    <Container>
      <div data-animate="fade-up">
        <Testimonials testimonials={testimonials} />
      </div>
    </Container>
  </Section>

  <!-- Stats -->
  <Section bg="primary">
    <Container>
      <div data-stagger class="grid grid-cols-2 lg:grid-cols-4 gap-8 text-center">
        <div>
          <p class="text-4xl font-bold text-white font-heading">{siteConfig.stats.yearsOfExperience}+</p>
          <p class="mt-1 text-white/70 text-sm">Años de experiencia</p>
        </div>
        <div>
          <p class="text-4xl font-bold text-white font-heading">{siteConfig.stats.patientsTreated}</p>
          <p class="mt-1 text-white/70 text-sm">Pacientes atendidos</p>
        </div>
        <div>
          <p class="text-4xl font-bold text-white font-heading">{siteConfig.stats.treatmentsCompleted}+</p>
          <p class="mt-1 text-white/70 text-sm">Tratamientos completados</p>
        </div>
        <div>
          <p class="text-4xl font-bold text-white font-heading">{siteConfig.stats.certifications}</p>
          <p class="mt-1 text-white/70 text-sm">Certificaciones</p>
        </div>
      </div>
    </Container>
  </Section>

  <CTASection />
</BaseLayout>
