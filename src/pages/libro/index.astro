---
import { Icon } from "astro-icon/components";
import BaseLayout from "../../layouts/BaseLayout.astro";
import HeroInner from "../../components/sections/HeroInner.astro";
import Section from "../../components/ui/Section.astro";
import Container from "../../components/ui/Container.astro";
---

<BaseLayout title="El Libro — Salud Evolutiva" description="Índice completo del libro Salud Evolutiva del Dr. Joaquín Ipinza. Lee los 7 capítulos gratis." ogImage="/images/og-libro.png">
  <HeroInner title="Salud Evolutiva" subtitle="La clave para tener dientes sanos — y de paso, todo lo demas" breadcrumbs={[{ label: "Inicio", href: "/" }, { label: "Libro", href: "/libro" }]} />
  <Section>
    <Container>
      <div class="max-w-3xl mx-auto">
        <div class="border-b border-neutral-200 pb-6 mb-2">
          <p class="text-sm text-neutral-400">Dr. Joaquín Ipinza Hofmann — DDS, MSc</p>
        </div>
        <div class="divide-y divide-neutral-100">
          <a href="/libro/palabras-del-autor" class="flex items-start gap-4 py-5 no-underline group hover:bg-primary-50/50 -mx-4 px-4 rounded-lg transition-colors">
            <span class="text-2xl font-heading font-bold text-primary-300 mt-0.5 shrink-0 flex items-center justify-center w-8 h-8">
              <Icon name="lucide:sparkles" class="w-5 h-5"  aria-hidden="true"/>
            </span>
            <div class="flex-1 min-w-0">
              <h2 class="font-heading font-semibold text-neutral-900 group-hover:text-primary-700 transition-colors">Palabras del Autor</h2>
              <p class="text-sm text-neutral-500 mt-0.5">Prólogo</p>
            </div>
            <Icon name="lucide:arrow-right" class="w-4 h-4 text-neutral-300 mt-1 shrink-0 group-hover:text-primary-500 transition-colors"  aria-hidden="true"/>
          </a>
          {[
            { slug: "capitulo-1", num: "1", title: "Evolucion Cultural vs Natural", sub: "Capítulo 1" },
            { slug: "capitulo-2", num: "2", title: "Salud Bucal: La Enfermedad de la Civilizacion", sub: "Capítulo 2" },
            { slug: "capitulo-3", num: "3", title: "El Tripode de la Salud", sub: "Capítulo 3" },
            { slug: "capitulo-4", num: "4", title: "Materiales Dentales y Toxicidad", sub: "Capítulo 4" },
            { slug: "capitulo-5", num: "5", title: "Salud Bucal a lo Largo de la Vida", sub: "Capítulo 5" },
          ].map((ch) => (
            <a href={`/libro/${ch.slug}`} class="flex items-start gap-4 py-5 no-underline group hover:bg-primary-50/50 -mx-4 px-4 rounded-lg transition-colors">
              <span class="text-2xl font-heading font-bold text-primary-300 mt-0.5 shrink-0">{ch.num}</span>
              <div class="flex-1 min-w-0">
                <h2 class="font-heading font-semibold text-neutral-900 group-hover:text-primary-700 transition-colors">{ch.title}</h2>
                <p class="text-sm text-neutral-500 mt-0.5">{ch.sub}</p>
              </div>
              <Icon name="lucide:arrow-right" class="w-4 h-4 text-neutral-300 mt-1 shrink-0 group-hover:text-primary-500 transition-colors"  aria-hidden="true"/>
            </a>
          ))}
          <a href="/libro/epilogo" class="flex items-start gap-4 py-5 no-underline group hover:bg-primary-50/50 -mx-4 px-4 rounded-lg transition-colors">
            <span class="text-2xl font-heading font-bold text-primary-300 mt-0.5 shrink-0 flex items-center justify-center w-8 h-8">
              <Icon name="lucide:sparkles" class="w-5 h-5"  aria-hidden="true"/>
            </span>
            <div class="flex-1 min-w-0">
              <h2 class="font-heading font-semibold text-neutral-900 group-hover:text-primary-700 transition-colors">Epílogo</h2>
              <p class="text-sm text-neutral-500 mt-0.5">Cierre</p>
            </div>
            <Icon name="lucide:arrow-right" class="w-4 h-4 text-neutral-300 mt-1 shrink-0 group-hover:text-primary-500 transition-colors"  aria-hidden="true"/>
          </a>
        </div>
      </div>
    </Container>
  </Section>
</BaseLayout>
