---
import BaseLayout from "../../layouts/BaseLayout.astro";
import HeroInner from "../../components/sections/HeroInner.astro";
import Section from "../../components/ui/Section.astro";
import Container from "../../components/ui/Container.astro";
---

<BaseLayout title="El Libro — Salud Evolutiva" description="Indice completo del libro Salud Evolutiva del Dr. Joaquin Ipinza. Lee los 7 capitulos gratis.">
  <HeroInner title="Salud Evolutiva" subtitle="La clave para tener dientes sanos — y de paso, todo lo demas" breadcrumbs={[{ label: "Inicio", href: "/" }, { label: "Libro", href: "/libro" }]} />
  <Section>
    <Container>
      <div class="max-w-3xl mx-auto">
        <div class="border-b border-neutral-200 pb-6 mb-2">
          <p class="text-sm text-neutral-400">Dr. Joaquin Ipinza Hofmann — DDS, MSc</p>
        </div>
        <div class="divide-y divide-neutral-100">
          <a href="/libro/palabras-del-autor" class="flex items-start gap-4 py-5 no-underline group hover:bg-primary-50/50 -mx-4 px-4 rounded-lg transition-colors">
            <span class="text-2xl font-heading font-bold text-primary-300 mt-0.5 shrink-0">✦</span>
            <div class="flex-1 min-w-0">
              <h2 class="font-heading font-semibold text-neutral-900 group-hover:text-primary-700 transition-colors">Palabras del Autor</h2>
              <p class="text-sm text-neutral-500 mt-0.5">Prologo</p>
            </div>
            <span class="text-neutral-300 mt-1 shrink-0 group-hover:text-primary-500 transition-colors">→</span>
          </a>
          <a href="/libro/capitulo-1" class="flex items-start gap-4 py-5 no-underline group hover:bg-primary-50/50 -mx-4 px-4 rounded-lg transition-colors">
            <span class="text-2xl font-heading font-bold text-primary-300 mt-0.5 shrink-0">1</span>
            <div class="flex-1 min-w-0">
              <h2 class="font-heading font-semibold text-neutral-900 group-hover:text-primary-700 transition-colors">Evolucion Cultural vs Natural</h2>
              <p class="text-sm text-neutral-500 mt-0.5">Capitulo 1</p>
            </div>
            <span class="text-neutral-300 mt-1 shrink-0 group-hover:text-primary-500 transition-colors">→</span>
          </a>
          <a href="/libro/capitulo-2" class="flex items-start gap-4 py-5 no-underline group hover:bg-primary-50/50 -mx-4 px-4 rounded-lg transition-colors">
            <span class="text-2xl font-heading font-bold text-primary-300 mt-0.5 shrink-0">2</span>
            <div class="flex-1 min-w-0">
              <h2 class="font-heading font-semibold text-neutral-900 group-hover:text-primary-700 transition-colors">Salud Bucal: La Enfermedad de la Civilizacion</h2>
              <p class="text-sm text-neutral-500 mt-0.5">Capitulo 2</p>
            </div>
            <span class="text-neutral-300 mt-1 shrink-0 group-hover:text-primary-500 transition-colors">→</span>
          </a>
          <a href="/libro/capitulo-3" class="flex items-start gap-4 py-5 no-underline group hover:bg-primary-50/50 -mx-4 px-4 rounded-lg transition-colors">
            <span class="text-2xl font-heading font-bold text-primary-300 mt-0.5 shrink-0">3</span>
            <div class="flex-1 min-w-0">
              <h2 class="font-heading font-semibold text-neutral-900 group-hover:text-primary-700 transition-colors">El Tripode de la Salud</h2>
              <p class="text-sm text-neutral-500 mt-0.5">Capitulo 3</p>
            </div>
            <span class="text-neutral-300 mt-1 shrink-0 group-hover:text-primary-500 transition-colors">→</span>
          </a>
          <a href="/libro/capitulo-4" class="flex items-start gap-4 py-5 no-underline group hover:bg-primary-50/50 -mx-4 px-4 rounded-lg transition-colors">
            <span class="text-2xl font-heading font-bold text-primary-300 mt-0.5 shrink-0">4</span>
            <div class="flex-1 min-w-0">
              <h2 class="font-heading font-semibold text-neutral-900 group-hover:text-primary-700 transition-colors">Materiales Dentales y Toxicidad</h2>
              <p class="text-sm text-neutral-500 mt-0.5">Capitulo 4</p>
            </div>
            <span class="text-neutral-300 mt-1 shrink-0 group-hover:text-primary-500 transition-colors">→</span>
          </a>
          <a href="/libro/capitulo-5" class="flex items-start gap-4 py-5 no-underline group hover:bg-primary-50/50 -mx-4 px-4 rounded-lg transition-colors">
            <span class="text-2xl font-heading font-bold text-primary-300 mt-0.5 shrink-0">5</span>
            <div class="flex-1 min-w-0">
              <h2 class="font-heading font-semibold text-neutral-900 group-hover:text-primary-700 transition-colors">Salud Bucal a lo Largo de la Vida</h2>
              <p class="text-sm text-neutral-500 mt-0.5">Capitulo 5</p>
            </div>
            <span class="text-neutral-300 mt-1 shrink-0 group-hover:text-primary-500 transition-colors">→</span>
          </a>
          <a href="/libro/epilogo" class="flex items-start gap-4 py-5 no-underline group hover:bg-primary-50/50 -mx-4 px-4 rounded-lg transition-colors">
            <span class="text-2xl font-heading font-bold text-primary-300 mt-0.5 shrink-0">✦</span>
            <div class="flex-1 min-w-0">
              <h2 class="font-heading font-semibold text-neutral-900 group-hover:text-primary-700 transition-colors">Epilogo</h2>
              <p class="text-sm text-neutral-500 mt-0.5">Cierre</p>
            </div>
            <span class="text-neutral-300 mt-1 shrink-0 group-hover:text-primary-500 transition-colors">→</span>
          </a>
        </div>
      </div>
    </Container>
  </Section>
</BaseLayout>