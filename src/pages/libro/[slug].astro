---
import { Icon } from "astro-icon/components";
import BaseLayout from "../../layouts/BaseLayout.astro";
import { getCollection } from "astro:content";

export async function getStaticPaths() {
  const chapters = await getCollection("chapters");
  return chapters.map((ch) => ({ params: { slug: ch.slug } }));
}

const { slug } = Astro.params;
const chapters = await getCollection("chapters");
const chapter = chapters.find((ch) => ch.slug === slug);
const { Content } = await chapter.render();
const { title, chapter_num, word_count } = chapter.data;

const sorted = [...chapters].sort((a, b) => (a.data.chapter_num || 0) - (b.data.chapter_num || 0));
const idx = sorted.findIndex((c) => c.slug === slug);
const prev = idx > 0 ? { slug: sorted[idx - 1].slug, title: sorted[idx - 1].data.title } : null;
const next = idx < sorted.length - 1 ? { slug: sorted[idx + 1].slug, title: sorted[idx + 1].data.title } : null;
const readTime = Math.max(1, Math.round((word_count || 200) / 250));
---

<BaseLayout title={`${title} — Salud Evolutiva`} description={`${title} — Capítulo del libro Salud Evolutiva del Dr. Ipinza. ${readTime} min de lectura.`}>
  <article class="max-w-3xl mx-auto px-4 sm:px-6 py-12 md:py-16">
    <nav class="text-sm text-neutral-500 mb-8 flex items-center gap-1.5 flex-wrap">
      <a href="/" class="hover:text-primary-700 no-underline text-neutral-500">Inicio</a>
      <Icon name="lucide:chevron-right" class="w-3.5 h-3.5 text-neutral-300"  aria-hidden="true"/>
      <a href="/libro" class="hover:text-primary-700 no-underline text-neutral-500">Libro</a>
      <Icon name="lucide:chevron-right" class="w-3.5 h-3.5 text-neutral-300"  aria-hidden="true"/>
      <span class="text-neutral-800 font-medium truncate max-w-[200px]">{title}</span>
    </nav>
    <header class="mb-10">
      <div class="flex items-center gap-3 mb-4 flex-wrap">
        {chapter_num ? <span class="badge-chapter">Capítulo {chapter_num}</span> : <span class="badge-chapter">Libro</span>}
        <span class="text-sm text-neutral-400">{word_count?.toLocaleString()} palabras</span>
        <span class="text-sm text-neutral-400">·</span>
        <span class="text-sm text-neutral-400">{readTime} min de lectura</span>
      </div>
      <h1 class="font-heading text-3xl md:text-4xl font-bold text-neutral-900 leading-tight">{title}</h1>
    </header>
    <div class="prose-evolutiva"><Content /></div>
    <nav class="chapter-nav">
      {prev ? (
        <a href={`/libro/${prev.slug}`}>
          <span class="nav-label inline-flex items-center gap-1"><Icon name="lucide:arrow-left" class="w-4 h-4"  aria-hidden="true"/> Anterior</span>
          <span class="nav-title">{prev.title}</span>
        </a>
      ) : <span />}
      {next ? (
        <a href={`/libro/${next.slug}`}>
          <span class="nav-label inline-flex items-center gap-1">Siguiente <Icon name="lucide:arrow-right" class="w-4 h-4"  aria-hidden="true"/></span>
          <span class="nav-title">{next.title}</span>
        </a>
      ) : <span />}
    </nav>
  </article>
  <button id="scroll-top-btn" class="fixed bottom-6 right-6 w-11 h-11 bg-primary-600 text-white rounded-full shadow-lg flex items-center justify-center opacity-0 pointer-events-none transition-opacity duration-200 hover:bg-primary-700 no-underline" aria-label="Volver arriba">
    <Icon name="lucide:arrow-up" class="w-5 h-5"  aria-hidden="true"/>
  </button>
  <script define:vars={{ prev: prev ? prev.slug : null, next: next ? next.slug : null }}>
    const btn = document.getElementById("scroll-top-btn");
    window.addEventListener("scroll", () => {
      if (window.scrollY > 600) { btn.classList.remove("opacity-0","pointer-events-none"); btn.classList.add("opacity-100"); }
      else { btn.classList.add("opacity-0","pointer-events-none"); btn.classList.remove("opacity-100"); }
    });
    btn.addEventListener("click", () => window.scrollTo({ top: 0, behavior: "smooth" }));
    document.addEventListener("keydown", (e) => {
      if (e.key === "ArrowLeft" && prev) window.location.href = "/libro/" + prev;
      if (e.key === "ArrowRight" && next) window.location.href = "/libro/" + next;
    });
  </script>
</BaseLayout>
