---
import BaseLayout from "../../layouts/BaseLayout.astro";
import HeroInner from "../../components/sections/HeroInner.astro";
import Section from "../../components/ui/Section.astro";
import Container from "../../components/ui/Container.astro";
import PlanAccionApp from "../../components/PlanAccion";
---

<BaseLayout title="Plan de Acción Personalizado | Centro de Salud Holística" description="Completa el cuestionario para recibir recomendaciones basadas en tu perfil." noindex={true}>
  <HeroInner
    title="Plan de Acción Personalizado"
    subtitle="Completa el cuestionario para recibir recomendaciones basadas en tu perfil"
    breadcrumbs={[
      { label: "Inicio", href: "/" },
      { label: "Mi Cuenta", href: "/mi-cuenta" },
      { label: "Plan de Acción", href: "/plan-accion" },
    ]}
  />

  <Section>
    <Container>
      <div class="max-w-2xl mx-auto">
        <div class="bg-white rounded-lg shadow-sm p-8">
          <PlanAccionApp client:load />
        </div>
      </div>
    </Container>
  </Section>
</BaseLayout>
