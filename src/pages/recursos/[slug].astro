---
import { Icon } from "astro-icon/components";
import BaseLayout from "../../layouts/BaseLayout.astro";
import ChecklistTool from "../../components/ChecklistTool";
import { getCollection } from "astro:content";

export async function getStaticPaths() {
  const tools = await getCollection("tools");
  return tools.map((t) => ({ params: { slug: t.slug } }));
}

const { slug } = Astro.params;
const tools = await getCollection("tools");
const tool = tools.find((t) => t.slug === slug);
const { Content } = await tool.render();
const { title, tool_type, word_count } = tool.data;
const readTime = Math.max(1, Math.round((word_count || 200) / 250));
const iconMap: Record<string,string> = { checklist: "lucide:circle-check", planner: "lucide:clipboard-list", guide: "lucide:book-open" };
const labels: Record<string,string> = { checklist: "Checklist", planner: "Planificador", guide: "Guia paso a paso" };
const badgeClass: Record<string,string> = { checklist: "badge-checklist", planner: "badge-planner", guide: "badge-tool" };
---

<BaseLayout title={`${title} — Salud Evolutiva`} description={tool.data.meta_description || title}>
  <article class="max-w-3xl mx-auto px-4 sm:px-6 py-12 md:py-16">
    <nav class="text-sm text-neutral-500 mb-8 flex items-center gap-1.5 flex-wrap">
      <a href="/" class="hover:text-primary-700 no-underline text-neutral-500">Inicio</a>
      <Icon name="lucide:chevron-right" class="w-3.5 h-3.5 text-neutral-300" />
      <a href="/recursos" class="hover:text-primary-700 no-underline text-neutral-500">Recursos</a>
      <Icon name="lucide:chevron-right" class="w-3.5 h-3.5 text-neutral-300" />
      <span class="text-neutral-800 font-medium truncate max-w-[200px]">{title}</span>
    </nav>
    <header class="mb-8">
      <div class="flex items-center gap-3 mb-3">
        <span class="text-2xl"><Icon name={iconMap[tool_type] || "lucide:wrench"} class="w-6 h-6" /></span>
        <span class={`${badgeClass[tool_type] || "badge-tool"} text-xs`}>{labels[tool_type] || "Herramienta"}</span>
      </div>
      <h1 class="font-heading text-3xl md:text-4xl font-bold text-neutral-900 leading-tight">{title}</h1>
      <div class="flex items-center gap-3 mt-4 text-sm text-neutral-400">
        <span>{word_count?.toLocaleString()} palabras</span>
        <span>·</span>
        <span>{readTime} min</span>
      </div>
    </header>
    {tool_type === "checklist" ? (
      <ChecklistTool client:load />
    ) : (
      <div class="prose-evolutiva"><Content /></div>
    )}
    <div class="mt-12 pt-8 border-t border-neutral-200">
      <a href="/recursos" class="text-sm font-medium text-primary-700 hover:text-primary-800 no-underline inline-flex items-center gap-1">
        <Icon name="lucide:arrow-left" class="w-4 h-4" /> Ver todas las herramientas
      </a>
    </div>
  </article>
</BaseLayout>
