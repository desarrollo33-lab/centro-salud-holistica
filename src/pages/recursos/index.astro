---
import { Icon } from "astro-icon/components";
import BaseLayout from "../../layouts/BaseLayout.astro";
import HeroInner from "../../components/sections/HeroInner.astro";
import Section from "../../components/ui/Section.astro";
import Container from "../../components/ui/Container.astro";
---

<BaseLayout title="Herramientas Prácticas — Salud Evolutiva" description="Checklists, planificadores y guías paso a paso para aplicar los conocimientos del libro Salud Evolutiva." ogImage="/images/og-recursos.png">
  <HeroInner title="Herramientas Prácticas" subtitle="Checklists, planificadores y guías paso a paso para aplicar los conocimientos" breadcrumbs={[{ label: "Inicio", href: "/" }, { label: "Recursos", href: "/recursos" }]} />
  <Section>
    <Container>
      <div class="max-w-3xl mx-auto">
        <h2 class="text-sm font-semibold text-neutral-400 uppercase tracking-wider mb-4 inline-flex items-center gap-2">
          <Icon name="lucide:circle-check" class="w-4 h-4"  aria-hidden="true"/> Checklists
        </h2>
        <div class="space-y-3 mb-10">
          {[
            { slug: "autoevaluacion-salud-bucal", title: "Autoevaluacion de Salud Bucal", desc: "Evalua el estado de tu salud bucal con este checklist completo." },
            { slug: "checklist-retiro-amalgamas", title: "Checklist para Retiro Seguro de Amalgamas", desc: "Todo lo que debes considerar antes de retirar empastes de amalgama." },
            { slug: "checklist-embarazo-dental", title: "Checklist Dental para el Embarazo", desc: "Cuidados bucales esenciales durante cada trimestre del embarazo." },
          ].map((t) => (
            <a href={`/recursos/${t.slug}`} class="group block bg-white rounded-lg p-5 shadow-sm hover:border-primary-300 hover:shadow-md transition-all no-underline">
              <h3 class="font-semibold text-neutral-900 group-hover:text-primary-700 transition-colors">{t.title}</h3>
              <p class="text-sm text-neutral-500 mt-1">{t.desc}</p>
            </a>
          ))}
        </div>
        <h2 class="text-sm font-semibold text-neutral-400 uppercase tracking-wider mb-4 inline-flex items-center gap-2">
          <Icon name="lucide:clipboard-list" class="w-4 h-4"  aria-hidden="true"/> Planificadores
        </h2>
        <div class="space-y-3 mb-10">
          {[{ slug: "plan-nutricional-semana-dental", title: "Plan Nutricional Semanal para Dientes Sanos", desc: "Menu semanal completo con lista de compras y recetas simples." }].map((t) => (
            <a href={`/recursos/${t.slug}`} class="group block bg-white rounded-lg p-5 shadow-sm hover:border-primary-300 hover:shadow-md transition-all no-underline">
              <h3 class="font-semibold text-neutral-900 group-hover:text-primary-700 transition-colors">{t.title}</h3>
              <p class="text-sm text-neutral-500 mt-1">{t.desc}</p>
            </a>
          ))}
        </div>
        <h2 class="text-sm font-semibold text-neutral-400 uppercase tracking-wider mb-4 inline-flex items-center gap-2">
          <Icon name="lucide:book-open" class="w-4 h-4"  aria-hidden="true"/> Guias paso a paso
        </h2>
        <div class="space-y-3">
          {[
            { slug: "guia-manejo-estres", title: "Guia Practica de Manejo del Estres para tu Salud Bucal", desc: "Tecnicas de relajacion y habitos que protegen tus encias." },
            { slug: "guia-sueno-optimo", title: "Guia del Sueno Optimo para tu Salud Dental", desc: "Como el descanso reparador influye en la salud de tu boca." },
            { slug: "guia-salud-dental-ninez", title: "Salud Dental Infantil: Guia por Edad", desc: "Recomendaciones desde el nacimiento hasta la adolescencia." },
            { slug: "guia-salud-dental-vejez", title: "Salud Dental en la Vejez: Guia Completa", desc: "Cuidados especificos para mantener una boca sana en la tercera edad." },
          ].map((t) => (
            <a href={`/recursos/${t.slug}`} class="group block bg-white rounded-lg p-5 shadow-sm hover:border-primary-300 hover:shadow-md transition-all no-underline">
              <h3 class="font-semibold text-neutral-900 group-hover:text-primary-700 transition-colors">{t.title}</h3>
              <p class="text-sm text-neutral-500 mt-1">{t.desc}</p>
            </a>
          ))}
        </div>
      </div>
    </Container>
  </Section>
</BaseLayout>
