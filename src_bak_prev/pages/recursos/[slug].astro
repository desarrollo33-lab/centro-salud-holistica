---
import Layout from '../../layouts/Layout.astro';
import { getCollection } from 'astro:content';
import ChecklistTool from '../../components/ChecklistTool';

export async function getStaticPaths() {
  const tools = await getCollection('tools');
  return tools.map(t => ({ params: { slug: t.slug } }));
}

const { slug } = Astro.params;
const tools = await getCollection('tools');
const tool = tools.find(t => t.slug === slug);
const { Content } = await tool.render();
const { title, tool_type, word_count } = tool.data;
const readTime = Math.max(1, Math.round((word_count || 200) / 250));

const icons: Record<string, string> = { checklist: "✅", planner: "📋", guide: "📖" };
const labels: Record<string, string> = { checklist: "Checklist", planner: "Planificador", guide: "Guía paso a paso" };
const badgeClasses: Record<string, string> = { checklist: "badge-checklist", planner: "badge-planner", guide: "badge-tool" };
---

<Layout title={title}>
  <article class="max-w-3xl mx-auto px-4 sm:px-6 py-10 md:py-14">
    <nav class="text-sm text-neutral-500 mb-8 flex items-center gap-1.5 flex-wrap">
      <a href="/" class="hover:text-primary-700 no-underline text-neutral-500">Inicio</a>
      <span class="text-neutral-300">›</span>
      <a href="/recursos" class="hover:text-primary-700 no-underline text-neutral-500">Herramientas</a>
      <span class="text-neutral-300">›</span>
      <span class="text-neutral-800 font-medium">{title}</span>
    </nav>

    <header class="mb-8">
      <div class="flex items-center gap-3 mb-3">
        <span class="text-2xl">{icons[tool_type] || "🛠️"}</span>
        <span class={`${badgeClasses[tool_type] || "badge-tool"} text-xs`}>{labels[tool_type] || "Herramienta"}</span>
      </div>
      <h1 class="font-heading text-3xl md:text-4xl font-bold text-neutral-900 leading-tight">{title}</h1>
      <div class="flex items-center gap-3 mt-4 text-sm text-neutral-400">
        <span>{word_count?.toLocaleString()} palabras</span>
        <span>·</span>
        <span>{readTime} min de lectura</span>
      </div>
    </header>

    {tool_type === "checklist" ? (
      <ChecklistTool client:load />
    ) : (
      <div class="prose-evolutiva">
        <Content />
      </div>
    )}

    <div class="mt-12 pt-8 border-t border-neutral-200">
      <a href="/recursos" class="text-sm font-medium text-primary-700 hover:text-primary-800 no-underline">← Ver todas las herramientas</a>
    </div>
  </article>
</Layout>
