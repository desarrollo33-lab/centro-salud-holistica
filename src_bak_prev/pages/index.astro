---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Salud Evolutiva — Educación en Salud Dental Gratuita">
  <!-- ═══ HERO ═══ -->
  <section class="relative bg-gradient-to-br from-primary-900 via-primary-800 to-primary-700 text-white overflow-hidden">
    <div class="absolute inset-0 opacity-10" style="background-image: radial-gradient(circle at 25% 50%, rgba(255,255,255,0.15) 0%, transparent 50%), radial-gradient(circle at 75% 25%, rgba(255,255,255,0.1) 0%, transparent 40%);"></div>
    <div class="relative max-w-5xl mx-auto px-4 sm:px-6 py-20 md:py-28">
      <div class="max-w-2xl">
        <div class="inline-flex items-center gap-2 bg-white/10 backdrop-blur-sm border border-white/20 rounded-full px-4 py-1.5 text-sm mb-6">
          <span class="w-2 h-2 bg-secondary-400 rounded-full"></span>
          Libro completo disponible gratis
        </div>
        <h1 class="font-heading text-3xl sm:text-4xl md:text-5xl font-bold leading-tight mb-6 text-pretty">
          Tu salud dental<br>comienza aquí
        </h1>
        <p class="text-lg md:text-xl text-primary-200 leading-relaxed mb-10 max-w-xl">
          Plataforma gratuita de educación en salud dental basada en el libro <em class="font-heading">Salud Evolutiva</em> del Dr. Joaquín Ipinza. Más de 30.000 palabras de contenido científico accesible.
        </p>
        <div class="flex flex-wrap gap-3">
          <a href="/libro" class="btn-primary">📖 Leer el libro completo</a>
          <a href="/aprende" class="btn-outline">📚 Guías prácticas</a>
        </div>
      </div>
    </div>
  </section>

  <!-- ═══ STATS BAR ═══ -->
  <section class="relative -mt-6 z-10">
    <div class="max-w-4xl mx-auto px-4 sm:px-6">
      <div class="bg-white rounded-2xl shadow-lg border border-neutral-100 p-6 md:p-8 grid grid-cols-2 md:grid-cols-4 gap-6 text-center">
        <div>
          <div class="text-3xl font-heading font-bold text-primary-800">7</div>
          <div class="text-sm text-neutral-500 mt-1">Capítulos del libro</div>
        </div>
        <div>
          <div class="text-3xl font-heading font-bold text-primary-800">5</div>
          <div class="text-sm text-neutral-500 mt-1">Guías prácticas</div>
        </div>
        <div>
          <div class="text-3xl font-heading font-bold text-primary-800">8</div>
          <div class="text-sm text-neutral-500 mt-1">Herramientas</div>
        </div>
        <div>
          <div class="text-3xl font-heading font-bold text-primary-800">25+</div>
          <div class="text-sm text-neutral-500 mt-1">Términos de glosario</div>
        </div>
      </div>
    </div>
  </section>

  <!-- ═══ ABOUT THE BOOK ═══ -->
  <section class="max-w-5xl mx-auto px-4 sm:px-6 py-16 md:py-20">
    <div class="max-w-3xl mx-auto text-center mb-12">
      <span class="badge-chapter mb-4 inline-block">📖 El Libro</span>
      <h2 class="font-heading text-2xl md:text-3xl font-bold text-neutral-900 mb-4">Salud Evolutiva — La clave para tener dientes sanos (y de paso, todo lo demás)</h2>
      <p class="text-neutral-600 leading-relaxed">
        El Dr. Joaquín Ipinza conecta la antropología dental con la odontología moderna, presentando evidencia científica de más de 150 referencias. Descubre por qué las enfermedades dentales son, en gran parte, enfermedades de civilización.
      </p>
    </div>
  </section>

  <!-- ═══ CHAPTERS ═══ -->
  <section class="bg-white py-16 md:py-20">
    <div class="max-w-5xl mx-auto px-4 sm:px-6">
      <div class="flex items-center justify-between mb-8">
        <h2 class="font-heading text-xl md:text-2xl font-bold text-neutral-900">Capítulos</h2>
        <a href="/libro" class="text-sm font-medium text-primary-700 hover:text-primary-800 no-underline">Ver índice completo →</a>
      </div>
      <div class="grid sm:grid-cols-2 gap-4">
        <a href="/libro/palabras-del-autor" class="card-hover block bg-neutral-50 rounded-xl p-5 border border-neutral-200 no-underline group">
          <span class="badge-chapter text-xs">Prólogo</span>
          <h3 class="font-heading font-semibold text-neutral-900 mt-2 group-hover:text-primary-700 transition-colors">Palabras del Autor</h3>
          <p class="text-sm text-neutral-500 mt-1">1.432 palabras</p>
        </a>
        <a href="/libro/capitulo-1" class="card-hover block bg-neutral-50 rounded-xl p-5 border border-neutral-200 no-underline group">
          <span class="badge-chapter text-xs">Capítulo 1</span>
          <h3 class="font-heading font-semibold text-neutral-900 mt-2 group-hover:text-primary-700 transition-colors">Evolución Cultural vs Natural</h3>
          <p class="text-sm text-neutral-500 mt-1">5.205 palabras</p>
        </a>
        <a href="/libro/capitulo-2" class="card-hover block bg-neutral-50 rounded-xl p-5 border border-neutral-200 no-underline group">
          <span class="badge-chapter text-xs">Capítulo 2</span>
          <h3 class="font-heading font-semibold text-neutral-900 mt-2 group-hover:text-primary-700 transition-colors">Salud Bucal: La Enfermedad de la Civilización</h3>
          <p class="text-sm text-neutral-500 mt-1">4.191 palabras</p>
        </a>
        <a href="/libro/capitulo-3" class="card-hover block bg-neutral-50 rounded-xl p-5 border border-neutral-200 no-underline group">
          <span class="badge-chapter text-xs">Capítulo 3</span>
          <h3 class="font-heading font-semibold text-neutral-900 mt-2 group-hover:text-primary-700 transition-colors">El Trípode de la Salud</h3>
          <p class="text-sm text-neutral-500 mt-1">7.819 palabras</p>
        </a>
        <a href="/libro/capitulo-4" class="card-hover block bg-neutral-50 rounded-xl p-5 border border-neutral-200 no-underline group">
          <span class="badge-chapter text-xs">Capítulo 4</span>
          <h3 class="font-heading font-semibold text-neutral-900 mt-2 group-hover:text-primary-700 transition-colors">Materiales Dentales y Toxicidad</h3>
          <p class="text-sm text-neutral-500 mt-1">7.276 palabras</p>
        </a>
        <a href="/libro/capitulo-5" class="card-hover block bg-neutral-50 rounded-xl p-5 border border-neutral-200 no-underline group">
          <span class="badge-chapter text-xs">Capítulo 5</span>
          <h3 class="font-heading font-semibold text-neutral-900 mt-2 group-hover:text-primary-700 transition-colors">Salud Bucal a lo Largo de la Vida</h3>
          <p class="text-sm text-neutral-500 mt-1">5.690 palabras</p>
        </a>
      </div>
    </div>
  </section>

  <!-- ═══ GUIDES ═══ -->
  <section class="max-w-5xl mx-auto px-4 sm:px-6 py-16 md:py-20">
    <div class="flex items-center justify-between mb-8">
      <h2 class="font-heading text-xl md:text-2xl font-bold text-neutral-900">📚 Guías Prácticas</h2>
      <a href="/aprende" class="text-sm font-medium text-primary-700 hover:text-primary-800 no-underline">Ver todas →</a>
    </div>
    <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-4">
      <a href="/aprende/vitamina-k2-guia-completa" class="card-hover block bg-white rounded-xl p-5 border border-neutral-200 no-underline group">
        <span class="badge-guide text-xs">Nutrición</span>
        <h3 class="font-heading font-semibold text-neutral-900 mt-2 group-hover:text-primary-700 transition-colors text-sm">Vitamina K2: La guía completa</h3>
        <p class="text-xs text-neutral-500 mt-2">Qué es, por qué la necesitas, y su relación con tus dientes</p>
      </a>
      <a href="/aprende/caries-prevencion-natural" class="card-hover block bg-white rounded-xl p-5 border border-neutral-200 no-underline group">
        <span class="badge-guide text-xs">Prevención</span>
        <h3 class="font-heading font-semibold text-neutral-900 mt-2 group-hover:text-primary-700 transition-colors text-sm">Caries: causas reales y prevención natural</h3>
        <p class="text-xs text-neutral-500 mt-2">Más allá del azúcar: por qué tenemos caries y cómo prevenirlas</p>
      </a>
      <a href="/aprende/enfermedad-periodontal-guia" class="card-hover block bg-white rounded-xl p-5 border border-neutral-200 no-underline group">
        <span class="badge-guide text-xs">Encías</span>
        <h3 class="font-heading font-semibold text-neutral-900 mt-2 group-hover:text-primary-700 transition-colors text-sm">Enfermedad periodontal: guía completa</h3>
        <p class="text-xs text-neutral-500 mt-2">La conexión entre tus encías y tu salud general</p>
      </a>
      <a href="/aprende/estres-y-salud-dental" class="card-hover block bg-white rounded-xl p-5 border border-neutral-200 no-underline group">
        <span class="badge-guide text-xs">Bienestar</span>
        <h3 class="font-heading font-semibold text-neutral-900 mt-2 group-hover:text-primary-700 transition-colors text-sm">Estrés y salud dental</h3>
        <p class="text-xs text-neutral-500 mt-2">La conexión que nadie te contó</p>
      </a>
      <a href="/aprende/nutricion-para-dientes-sanos" class="card-hover block bg-white rounded-xl p-5 border border-neutral-200 no-underline group">
        <span class="badge-guide text-xs">Alimentación</span>
        <h3 class="font-heading font-semibold text-neutral-900 mt-2 group-hover:text-primary-700 transition-colors text-sm">Nutrición para dientes sanos</h3>
        <p class="text-xs text-neutral-500 mt-2">Qué comer según la ciencia evolutiva</p>
      </a>
    </div>
  </section>

  <!-- ═══ TOOLS ═══ -->
  <section class="bg-white py-16 md:py-20">
    <div class="max-w-5xl mx-auto px-4 sm:px-6">
      <div class="flex items-center justify-between mb-8">
        <h2 class="font-heading text-xl md:text-2xl font-bold text-neutral-900">🛠️ Herramientas Prácticas</h2>
        <a href="/recursos" class="text-sm font-medium text-primary-700 hover:text-primary-800 no-underline">Ver todas →</a>
      </div>
      <div class="grid sm:grid-cols-2 lg:grid-cols-4 gap-4">
        <a href="/recursos/autoevaluacion-salud-bucal" class="card-hover block bg-neutral-50 rounded-xl p-4 border border-neutral-200 no-underline group text-center">
          <div class="text-2xl mb-2">✅</div>
          <span class="badge-checklist text-xs">Checklist</span>
          <h3 class="font-semibold text-neutral-900 mt-2 group-hover:text-primary-700 transition-colors text-sm">Autoevaluación de salud bucal</h3>
        </a>
        <a href="/recursos/plan-nutricional-semana-dental" class="card-hover block bg-neutral-50 rounded-xl p-4 border border-neutral-200 no-underline group text-center">
          <div class="text-2xl mb-2">📋</div>
          <span class="badge-planner text-xs">Planificador</span>
          <h3 class="font-semibold text-neutral-900 mt-2 group-hover:text-primary-700 transition-colors text-sm">Plan nutricional semanal</h3>
        </a>
        <a href="/recursos/guia-salud-dental-ninez" class="card-hover block bg-neutral-50 rounded-xl p-4 border border-neutral-200 no-underline group text-center">
          <div class="text-2xl mb-2">👶</div>
          <span class="badge-tool text-xs">Guía</span>
          <h3 class="font-semibold text-neutral-900 mt-2 group-hover:text-primary-700 transition-colors text-sm">Salud dental infantil</h3>
        </a>
        <a href="/recursos/guia-salud-dental-vejez" class="card-hover block bg-neutral-50 rounded-xl p-4 border border-neutral-200 no-underline group text-center">
          <div class="text-2xl mb-2">🧓</div>
          <span class="badge-tool text-xs">Guía</span>
          <h3 class="font-semibold text-neutral-900 mt-2 group-hover:text-primary-700 transition-colors text-sm">Salud dental en la vejez</h3>
        </a>
      </div>
    </div>
  </section>

  <!-- ═══ ABOUT CTA ═══ -->
  <section class="max-w-5xl mx-auto px-4 sm:px-6 py-16 md:py-20">
    <div class="bg-gradient-to-br from-primary-50 to-secondary-50 rounded-2xl p-8 md:p-12 text-center border border-primary-100">
      <div class="text-4xl mb-4">👨‍⚕️</div>
      <h2 class="font-heading text-2xl md:text-3xl font-bold text-neutral-900 mb-4">Sobre el Dr. Ipinza</h2>
      <p class="text-neutral-600 max-w-2xl mx-auto mb-6 leading-relaxed">
        Cirujano Dentista de la Universidad de Chile, especialista en Periodoncia, Magíster en Ciencias y especialista en Implantología buco-maxilo-facial (Loma Linda, California). Su misión es poner el conocimiento de salud dental al alcance de todas las personas.
      </p>
      <a href="/sobre" class="btn-primary">Conocer más →</a>
    </div>
  </section>
</Layout>
