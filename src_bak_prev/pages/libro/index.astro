---
import Layout from '../../layouts/Layout.astro';
---

<Layout title="El Libro — Salud Evolutiva" description="Índice completo del libro Salud Evolutiva del Dr. Joaquín Ipinza. Lee los 7 capítulos gratis.">
  <div class="max-w-3xl mx-auto px-4 sm:px-6 py-10 md:py-14">
    <!-- Breadcrumb -->
    <nav class="text-sm text-neutral-500 mb-8 flex items-center gap-1.5">
      <a href="/" class="hover:text-primary-700 no-underline text-neutral-500">Inicio</a>
      <span class="text-neutral-300">›</span>
      <span class="text-neutral-800 font-medium">Libro</span>
    </nav>

    <div class="mb-10">
      <h1 class="font-heading text-3xl md:text-4xl font-bold text-neutral-900 mb-2">Salud Evolutiva</h1>
      <p class="text-lg text-neutral-600">La clave para tener dientes sanos (y de paso, todo lo demás)</p>
      <p class="text-sm text-neutral-500 mt-2">Dr. Joaquín Ipinza Hofmann — DDS, MSc</p>
    </div>

    <div class="border-t border-neutral-200 pt-6 space-y-0 divide-y divide-neutral-100">
      <a href="/libro/palabras-del-autor" class="flex items-start gap-4 py-5 no-underline group hover:bg-primary-50/50 -mx-4 px-4 rounded-lg transition-colors">
        <span class="text-2xl font-heading font-bold text-primary-200 mt-0.5 shrink-0">✦</span>
        <div class="flex-1 min-w-0">
          <h2 class="font-heading font-semibold text-neutral-900 group-hover:text-primary-700 transition-colors">Palabras del Autor</h2>
          <p class="text-sm text-neutral-500 mt-0.5">Prólogo — 1.432 palabras</p>
        </div>
        <span class="text-neutral-300 mt-1 shrink-0 group-hover:text-primary-500 transition-colors">→</span>
      </a>
      <a href="/libro/capitulo-1" class="flex items-start gap-4 py-5 no-underline group hover:bg-primary-50/50 -mx-4 px-4 rounded-lg transition-colors">
        <span class="text-2xl font-heading font-bold text-primary-200 mt-0.5 shrink-0">1</span>
        <div class="flex-1 min-w-0">
          <h2 class="font-heading font-semibold text-neutral-900 group-hover:text-primary-700 transition-colors">Evolución Cultural vs Natural</h2>
          <p class="text-sm text-neutral-500 mt-0.5">5.205 palabras</p>
        </div>
        <span class="text-neutral-300 mt-1 shrink-0 group-hover:text-primary-500 transition-colors">→</span>
      </a>
      <a href="/libro/capitulo-2" class="flex items-start gap-4 py-5 no-underline group hover:bg-primary-50/50 -mx-4 px-4 rounded-lg transition-colors">
        <span class="text-2xl font-heading font-bold text-primary-200 mt-0.5 shrink-0">2</span>
        <div class="flex-1 min-w-0">
          <h2 class="font-heading font-semibold text-neutral-900 group-hover:text-primary-700 transition-colors">Salud Bucal: La Enfermedad de la Civilización</h2>
          <p class="text-sm text-neutral-500 mt-0.5">4.191 palabras</p>
        </div>
        <span class="text-neutral-300 mt-1 shrink-0 group-hover:text-primary-500 transition-colors">→</span>
      </a>
      <a href="/libro/capitulo-3" class="flex items-start gap-4 py-5 no-underline group hover:bg-primary-50/50 -mx-4 px-4 rounded-lg transition-colors">
        <span class="text-2xl font-heading font-bold text-primary-200 mt-0.5 shrink-0">3</span>
        <div class="flex-1 min-w-0">
          <h2 class="font-heading font-semibold text-neutral-900 group-hover:text-primary-700 transition-colors">El Trípode de la Salud</h2>
          <p class="text-sm text-neutral-500 mt-0.5">7.819 palabras</p>
        </div>
        <span class="text-neutral-300 mt-1 shrink-0 group-hover:text-primary-500 transition-colors">→</span>
      </a>
      <a href="/libro/capitulo-4" class="flex items-start gap-4 py-5 no-underline group hover:bg-primary-50/50 -mx-4 px-4 rounded-lg transition-colors">
        <span class="text-2xl font-heading font-bold text-primary-200 mt-0.5 shrink-0">4</span>
        <div class="flex-1 min-w-0">
          <h2 class="font-heading font-semibold text-neutral-900 group-hover:text-primary-700 transition-colors">Materiales Dentales y Toxicidad</h2>
          <p class="text-sm text-neutral-500 mt-0.5">7.276 palabras</p>
        </div>
        <span class="text-neutral-300 mt-1 shrink-0 group-hover:text-primary-500 transition-colors">→</span>
      </a>
      <a href="/libro/capitulo-5" class="flex items-start gap-4 py-5 no-underline group hover:bg-primary-50/50 -mx-4 px-4 rounded-lg transition-colors">
        <span class="text-2xl font-heading font-bold text-primary-200 mt-0.5 shrink-0">5</span>
        <div class="flex-1 min-w-0">
          <h2 class="font-heading font-semibold text-neutral-900 group-hover:text-primary-700 transition-colors">Salud Bucal a lo Largo de la Vida</h2>
          <p class="text-sm text-neutral-500 mt-0.5">5.690 palabras</p>
        </div>
        <span class="text-neutral-300 mt-1 shrink-0 group-hover:text-primary-500 transition-colors">→</span>
      </a>
      <a href="/libro/epilogo" class="flex items-start gap-4 py-5 no-underline group hover:bg-primary-50/50 -mx-4 px-4 rounded-lg transition-colors">
        <span class="text-2xl font-heading font-bold text-primary-200 mt-0.5 shrink-0">✦</span>
        <div class="flex-1 min-w-0">
          <h2 class="font-heading font-semibold text-neutral-900 group-hover:text-primary-700 transition-colors">Epílogo</h2>
          <p class="text-sm text-neutral-500 mt-0.5">254 palabras</p>
        </div>
        <span class="text-neutral-300 mt-1 shrink-0 group-hover:text-primary-500 transition-colors">→</span>
      </a>
    </div>
  </div>
</Layout>
